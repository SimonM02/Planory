  });

  state.tagebuch.push({
    id: Date.now(),
    datum: document.getElementById('tb-datum').value || today(),
    title: document.getElementById('tb-title').value || 'Eintrag',
    text: document.getElementById('tb-text').value,
    weather: document.getElementById('tb-weather').value,
    tags: document.getElementById('tb-tags').value.split(',').map(t=>t.trim()).filter(Boolean),
    workers
  });
