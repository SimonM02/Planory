function addDokuPhotos(input) {
  const files = Array.from(input.files);
  files.forEach(file => {
    const reader = new FileReader();
    reader.onload = e => {
      dokuPendingPhotos.push({ data: e.target.result, name: file.name });
      renderDokuPhotoPreviews();
    };
    reader.readAsDataURL(file);
  });
  input.value = '';
}

function renderDokuPhotoPreviews() {
  const container = document.getElementById('dk-photo-previews');
  if (!container) return;
  container.innerHTML = dokuPendingPhotos.map((p, i) => `
    <div style="position:relative;display:inline-block">
      <img src="${p.data}" style="width:72px;height:72px;object-fit:cover;border-radius:8px;border:1.5px solid var(--border);display:block">
      <button onclick="dokuPendingPhotos.splice(${i},1);renderDokuPhotoPreviews()"
        style="position:absolute;top:-6px;right:-6px;background:var(--danger);border:none;color:white;border-radius:50%;width:18px;height:18px;font-size:0.65rem;cursor:pointer;line-height:1;display:flex;align-items:center;justify-content:center">✕</button>
    </div>`).join('');
}

function addDoku() {
  state.dokumentation = state.dokumentation || [];
  state.dokumentation.push({
    id: Date.now(),
    title:   document.getElementById('dk-title').value || 'Eintrag',
    typ:     document.getElementById('dk-typ').value,
    raum:    document.getElementById('dk-raum').value,
    text:    document.getElementById('dk-text').value,
    hinweis: document.getElementById('dk-hinweis').value,
    datum:   document.getElementById('dk-datum').value || today(),
    tags:    document.getElementById('dk-tags').value.split(',').map(t => t.trim()).filter(Boolean),
    fotos:   [...dokuPendingPhotos]
  });
  save();
  closeModal('modal-doku');
  ['dk-title','dk-raum','dk-text','dk-hinweis','dk-datum','dk-tags'].forEach(id => document.getElementById(id).value = '');
  dokuPendingPhotos = [];
  const prev = document.getElementById('dk-photo-previews');
  if (prev) prev.innerHTML = '';
  renderDoku();
}

function deleteDoku(id) {
  if (!confirm('Eintrag löschen?')) return;
  state.dokumentation = state.dokumentation.filter(d => d.id !== id);
  save(); renderDoku();
}

