function addGanttItem() {
  const start = document.getElementById('g-start').value;
  const end = document.getElementById('g-end').value;
  if (!start || !end) { alert('Bitte Start- und Enddatum angeben!'); return; }
  state.gantt.push({
    id: Date.now(),
    name: document.getElementById('g-name').value || 'Neue Phase',
    type: document.getElementById('g-type').value,
    start, end,
    status: document.getElementById('g-status').value,
    notiz: document.getElementById('g-notiz').value
  });
  save(); closeModal('modal-gantt');
  ['g-name','g-start','g-end','g-notiz'].forEach(id => document.getElementById(id).value = '');
  renderGantt();
}

function deleteGanttItem(id) {
  state.gantt = state.gantt.filter(g => g.id !== id);
  save(); renderGantt();
}

function renderGantt() {
  const el = document.getElementById('gantt-chart');
  if (state.gantt.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">📅</div><p>Noch keine Phasen – füge deine erste Bauphase hinzu!</p></div>`;
    return;
  }

  // determine date range
  const allDates = state.gantt.flatMap(g => [new Date(g.start), new Date(g.end)]);
  let minDate = new Date(Math.min(...allDates));
  let maxDate = new Date(Math.max(...allDates));
  minDate = new Date(minDate.getFullYear(), minDate.getMonth(), 1);
  maxDate = new Date(maxDate.getFullYear(), maxDate.getMonth() + 1, 0);

  const totalMs = maxDate - minDate;

  // build months list
  const months = [];
  let cur = new Date(minDate);
  while (cur <= maxDate) {
    months.push(new Date(cur));
    cur = new Date(cur.getFullYear(), cur.getMonth() + 1, 1);
  }

  const monthNames = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];

  const pct = (d) => Math.max(0, Math.min(100, (new Date(d) - minDate) / totalMs * 100));
  const todayPct = pct(new Date());

  const sorted = [...state.gantt].sort((a,b) => new Date(a.start) - new Date(b.start));

  const colors = {
    phase: { open:'#c8a96e', progress:'#e8a838', done:'#5cb85c' },
    task:  { open:'#64a0f0', progress:'#d95fab', done:'#5cb85c' }
  };

  el.innerHTML = `
    <div class="gantt-grid">
      <div class="gantt-header-row">
        <div class="gantt-label-col">Phase / Aufgabe</div>
        <div class="gantt-month-headers">
          ${months.map(m => `<div class="gantt-month-header">${monthNames[m.getMonth()]} ${m.getFullYear()}</div>`).join('')}
        </div>
      </div>
      ${sorted.map(g => {
        const left = pct(g.start);
        const width = Math.max(0.5, pct(g.end) - left);
        const colorKey = g.status === 'Erledigt' ? 'done' : g.status === 'In Arbeit' ? 'progress' : 'open';
        const color = (colors[g.type] || colors.task)[colorKey];
        return `
          <div class="gantt-row" title="${g.name}: ${fmtDate(g.start)} – ${fmtDate(g.end)}">
            <div class="gantt-row-label">
              <span>${g.name}</span>
              <small>${g.type === 'phase' ? '📋 Phase' : '✅ Aufgabe'} · <span class="badge badge-${g.status==='Erledigt'?'green':g.status==='In Arbeit'?'yellow':'gray'}" style="padding:1px 6px;font-size:0.6rem">${g.status}</span></small>
            </div>
            <div class="gantt-timeline">
              <div style="position:absolute;top:0;bottom:0;left:${todayPct}%;width:2px;background:var(--accent);opacity:0.6;z-index:2"></div>
              <div class="gantt-bar" style="left:${left}%;width:${width}%;background:${color};color:${g.status==='Erledigt'?'#0f0e0c':'#0f0e0c'}">
                ${width > 5 ? g.name : ''}
              </div>
              <button class="action-btn del" style="position:absolute;right:4px;top:50%;transform:translateY(-50%)" onclick="deleteGanttItem(${g.id})">🗑</button>
            </div>
          </div>`;
      }).join('')}
    </div>`;
}

// ──────────────── FOTOS ────────────────
let pendingPhoto = null;

function addPhotos(input) {
  const files = Array.from(input.files);
  if (files.length === 0) return;
  // process one by one, show modal for first
  let idx = 0;
  function processNext() {
    if (idx >= files.length) { renderFotos(); return; }
    const file = files[idx++];
    const reader = new FileReader();
    reader.onload = e => {
      pendingPhoto = { data: e.target.result, file: file.name };
      document.getElementById('fi-title').value = file.name.replace(/\.[^.]+$/, '').replace(/[-_]/g,' ');
      document.getElementById('fi-datum').value = today();
      openModal('modal-foto-info');
      // after confirm, processNext is called
      document.getElementById('modal-foto-info')._next = processNext;
    };
    reader.readAsDataURL(file);
  }
  processNext();
  input.value = '';
}

function confirmPhoto() {
  if (!pendingPhoto) return;
  state.fotos.push({
    id: Date.now(),
    data: pendingPhoto.data,
    title: document.getElementById('fi-title').value || 'Foto',
    kat: document.getElementById('fi-kat').value,
    datum: document.getElementById('fi-datum').value || today()
  });
  save();
  closeModal('modal-foto-info');
  pendingPhoto = null;
  const nextFn = document.getElementById('modal-foto-info')._next;
  if (nextFn) nextFn();
  renderFotos();
}

function deletePhoto(id) {
  if (!confirm('Foto löschen?')) return;
  state.fotos = state.fotos.filter(f => f.id !== id);
  save(); renderFotos();
}

function openLightbox(id) {
  const f = state.fotos.find(f => f.id === id);
  if (!f) return;
  document.getElementById('lightbox-img').src = f.data;
  document.getElementById('lightbox-title').textContent = f.title;
  document.getElementById('lightbox-meta').textContent = f.kat + ' · ' + fmtDate(f.datum);
  document.getElementById('lightbox').classList.add('open');
}

function closeLightbox() { document.getElementById('lightbox').classList.remove('open'); }

function renderFotos() {
  const search = (document.getElementById('foto-search')?.value || '').toLowerCase();
  const filterKat = document.getElementById('foto-filter')?.value || '';
  const items = state.fotos.filter(f =>
    f.title.toLowerCase().includes(search) &&
    (!filterKat || f.kat === filterKat)
  );
  const el = document.getElementById('photo-grid');
  if (items.length === 0) {
    el.innerHTML = `<div class="empty" style="grid-column:1/-1"><div class="icon">📸</div><p>Noch keine Fotos – lade dein erstes Bild hoch!</p></div>`;
    return;
  }
  el.innerHTML = [...items].reverse().map(f => `
    <div class="photo-card" onclick="openLightbox(${f.id})">
      <button class="photo-card-del" onclick="event.stopPropagation();deletePhoto(${f.id})">🗑</button>
      <img src="${f.data}" alt="${f.title}" loading="lazy">
      <div class="photo-card-info">
        <div class="photo-card-title">${f.title}</div>
        <div class="photo-card-meta">${f.kat} · ${fmtDate(f.datum)}</div>
      </div>
    </div>`).join('');
}

// ──────────────── KOSTENENTWICKLUNG CHART ────────────────
let activeChart = null;
let activeTopChart = null;
let currentChartMode = 'monthly';

function switchChart(mode, btn) {
  currentChartMode = mode;
  document.querySelectorAll('.chart-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  renderKostenChart();
}

function renderKostenChart() {
  if (state.kosten.length === 0) {
    const ctx = document.getElementById('cost-chart');
    if (ctx) ctx.getContext('2d').clearRect(0,0,ctx.width,ctx.height);
    document.getElementById('cost-stats').innerHTML = '<p style="color:var(--text3);font-size:0.85rem">Noch keine Ausgaben erfasst.</p>';
    return;
  }

  const paid = state.kosten.filter(k => k.status !== 'Storniert');

  if (currentChartMode === 'monthly') {
    // group by month
    const byMonth = {};
    paid.forEach(k => {
      const d = new Date(k.datum);
      const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
      byMonth[key] = (byMonth[key]||0) + (parseFloat(k.betrag)||0);
    });
    const labels = Object.keys(byMonth).sort();
    const data = labels.map(l => byMonth[l]);
    const monthNames = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
    const prettyLabels = labels.map(l => { const [y,m] = l.split('-'); return monthNames[parseInt(m)-1] + ' ' + y; });
    drawBarChart('cost-chart', prettyLabels, data, 'Ausgaben pro Monat (€)');

  } else if (currentChartMode === 'cumulative') {
    const sorted = [...paid].sort((a,b) => new Date(a.datum)-new Date(b.datum));
    const labels = sorted.map(k => fmtDate(k.datum));
    let cum = 0;
    const data = sorted.map(k => { cum += parseFloat(k.betrag)||0; return cum; });
    const budget = state.settings.budget;
    drawLineChart('cost-chart', labels, data, 'Kumulierte Kosten (€)', budget);

  } else if (currentChartMode === 'category') {
    const byCat = {};
    paid.forEach(k => { byCat[k.kat] = (byCat[k.kat]||0) + (parseFloat(k.betrag)||0); });
    const labels = Object.keys(byCat);
    const data = labels.map(l => byCat[l]);
    drawDoughnutChart('cost-chart', labels, data);
  }

  // top spending chart
  const byCat2 = {};
  paid.forEach(k => { byCat2[k.kat] = (byCat2[k.kat]||0) + (parseFloat(k.betrag)||0); });
  const sorted2 = Object.entries(byCat2).sort((a,b)=>b[1]-a[1]).slice(0,5);
  drawBarChart('top-chart', sorted2.map(x=>x[0]), sorted2.map(x=>x[1]), 'Top Kategorien (€)', true);

  // stats
  const total = paid.reduce((s,k) => s + (parseFloat(k.betrag)||0), 0);
  const avg = paid.length ? total/paid.length : 0;
  const max = paid.reduce((m,k) => Math.max(m, parseFloat(k.betrag)||0), 0);
  const pct = state.settings.budget > 0 ? (total/state.settings.budget*100).toFixed(1) : '–';
  document.getElementById('cost-stats').innerHTML = [
    ['Gesamtausgaben', fmt(total)],
    ['Ø pro Buchung', fmt(avg)],
    ['Größte Ausgabe', fmt(max)],
    ['Budgetverbrauch', pct !== '–' ? pct+'%' : '–'],
    ['Anzahl Buchungen', paid.length],
  ].map(([l,v]) => `
    <div style="display:flex;justify-content:space-between;align-items:center;padding:8px 0;border-bottom:1px solid var(--border)">
      <span style="font-size:0.82rem;color:var(--text2)">${l}</span>
      <span style="font-family:'DM Mono',monospace;font-size:0.85rem;color:var(--accent)">${v}</span>
    </div>`).join('');
}

const CHART_COLORS = ['#c8a96e','#64a0f0','#5cb85c','#e8a838','#d95fab','#5cc8c8','#e85858','#b8c86e','#a06ed9'];

function chartDefaults() {
  return {
    plugins: { legend: { labels: { color: '#64748b', font: { family: 'Plus Jakarta Sans', size: 11 } } } },
    scales: {
      x: { ticks: { color: '#94a3b8', font: { family: 'DM Mono', size: 10 } }, grid: { color: '#e2e8f4' } },
      y: { ticks: { color: '#94a3b8', font: { family: 'DM Mono', size: 10 }, callback: v => '€'+v.toLocaleString('de-AT') }, grid: { color: '#e2e8f4' } }
    }
  };
}

function drawBarChart(canvasId, labels, data, label, horizontal=false) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (canvas._chart) canvas._chart.destroy();
  canvas._chart = new Chart(canvas, {
    type: 'bar',
    data: { labels, datasets: [{ label, data, backgroundColor: CHART_COLORS.slice(0,data.length), borderRadius: 6, borderSkipped: false }] },
    options: { ...chartDefaults(), indexAxis: horizontal ? 'y' : 'x', plugins: { legend: { display: false } }, responsive: true }
  });
}

function drawLineChart(canvasId, labels, data, label, budget) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (canvas._chart) canvas._chart.destroy();
  const datasets = [{
    label, data,
    borderColor: '#c8a96e', backgroundColor: 'rgba(200,169,110,0.12)',
    fill: true, tension: 0.3, pointRadius: 3, pointBackgroundColor: '#c8a96e'
  }];
  if (budget > 0) {
    datasets.push({
      label: 'Budget',
      data: labels.map(() => budget),
      borderColor: '#d9534f', borderDash: [6,4], pointRadius: 0,
      backgroundColor: 'transparent'
    });
  }
  canvas._chart = new Chart(canvas, {
    type: 'line',
    data: { labels, datasets },
    options: { ...chartDefaults(), responsive: true }
  });
}

function drawDoughnutChart(canvasId, labels, data) {
  const canvas = document.getElementById(canvasId);
  if (!canvas) return;
  if (canvas._chart) canvas._chart.destroy();
  canvas._chart = new Chart(canvas, {
    type: 'doughnut',
    data: { labels, datasets: [{ data, backgroundColor: CHART_COLORS, borderWidth: 2, borderColor: '#1a1814' }] },
    options: {
      responsive: true,
      plugins: { legend: { position: 'right', labels: { color: '#9a9284', font: { family: 'DM Mono', size: 11 } } } },
      scales: { x: { display: false }, y: { display: false } }
    }
  });
}

