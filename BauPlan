function deleteDiary(id) {
  if (!confirm('Eintrag löschen?')) return;
  state.tagebuch = state.tagebuch.filter(e => e.id !== id);
  save(); renderDiary();
}

function renderDiary() {
  const el = document.getElementById('diary-list');
  if (state.tagebuch.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">📓</div><p>Noch keine Einträge – starte dein Bautagebuch!</p></div>`;
    return;
  }
  el.innerHTML = [...state.tagebuch].reverse().map(e => {
    const workers = e.workers || [];
    const totalHours = workers.reduce((s,w) => s + (w.hours||0), 0);
    return `
    <div class="diary-entry">
      <div class="diary-actions">
        <button class="action-btn del" onclick="deleteDiary(${e.id})">🗑</button>
      </div>
      <div class="diary-date">${fmtDate(e.datum)} · ${e.weather}</div>
      <div class="diary-title">${e.title}</div>
      <div class="diary-text">${e.text.replace(/\n/g,'<br>')}</div>
      ${workers.length ? `
        <div style="margin-top:12px;background:var(--surface2);border-radius:8px;padding:12px">
          <div style="font-family:'DM Mono',monospace;font-size:0.62rem;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px">
            👷 Mannschaft · ${totalHours} Stunden gesamt
          </div>
          <div style="display:flex;flex-wrap:wrap;gap:6px">
            ${workers.map(w => `
              <div style="background:var(--surface);border:1px solid var(--border);border-radius:6px;padding:4px 10px;display:flex;gap:8px;align-items:center">
                <span style="font-size:0.84rem">${w.name}</span>
                <span style="font-family:'DM Mono',monospace;font-size:0.72rem;color:var(--accent)">${w.hours}h</span>
              </div>`).join('')}
          </div>
        </div>` : ''}
      ${e.tags.length ? `<div class="diary-tags">${e.tags.map(t=>`<span class="badge badge-gray">${t}</span>`).join('')}</div>` : ''}
    </div>`;
  }).join('');
}

function renderDiarySummary() {
  const el = document.getElementById('diary-summary');
  if (state.tagebuch.length === 0) {
    el.innerHTML = `<div class="empty"><div class="icon">📊</div><p>Noch keine Einträge vorhanden.</p></div>`;
    return;
  }

  // aggregate worker stats
  const workerMap = {};
  let totalAllHours = 0;
  let daysWithWorkers = 0;

  state.tagebuch.forEach(e => {
    const workers = e.workers || [];
    if (workers.length > 0) daysWithWorkers++;
    workers.forEach(w => {
      if (!workerMap[w.name]) workerMap[w.name] = { days: 0, hours: 0, dates: [] };
      workerMap[w.name].days++;
      workerMap[w.name].hours += w.hours || 0;
      workerMap[w.name].dates.push(e.datum);
      totalAllHours += w.hours || 0;
    });
  });

  const sorted = Object.entries(workerMap).sort((a,b) => b[1].hours - a[1].hours);

  // hours per month
  const byMonth = {};
  state.tagebuch.forEach(e => {
    const d = new Date(e.datum);
    const key = `${d.getFullYear()}-${String(d.getMonth()+1).padStart(2,'0')}`;
    const hrs = (e.workers||[]).reduce((s,w) => s + (w.hours||0), 0);
    byMonth[key] = (byMonth[key]||0) + hrs;
  });
  const monthKeys = Object.keys(byMonth).sort();
  const monthNames = ['Jan','Feb','Mär','Apr','Mai','Jun','Jul','Aug','Sep','Okt','Nov','Dez'];
  const prettyMonths = monthKeys.map(k => { const [y,m] = k.split('-'); return monthNames[parseInt(m)-1]+' '+y; });

  el.innerHTML = `
    <div class="cards-grid" style="margin-bottom:24px">
      <div class="card">
        <div class="card-label">Arbeitsstunden gesamt</div>
        <div class="card-value yellow">${totalAllHours.toFixed(1)} h</div>
        <div class="card-sub">über alle Einträge</div>
      </div>
      <div class="card">
        <div class="card-label">Arbeitstage</div>
        <div class="card-value">${daysWithWorkers}</div>
        <div class="card-sub">Tage mit Mannschaft</div>
      </div>
      <div class="card">
        <div class="card-label">Verschiedene Arbeiter</div>
        <div class="card-value">${sorted.length}</div>
        <div class="card-sub">Personen eingesetzt</div>
      </div>
      <div class="card">
        <div class="card-label">Ø Stunden / Tag</div>
        <div class="card-value">${daysWithWorkers ? (totalAllHours/daysWithWorkers).toFixed(1) : '0'} h</div>
        <div class="card-sub">pro Einsatztag</div>
      </div>
    </div>

    ${sorted.length > 0 ? `
    <div class="table-wrap" style="margin-bottom:24px">
      <div class="table-header"><div class="table-title">Stunden nach Arbeiter</div></div>
      <table>
        <thead><tr><th>Name</th><th>Einsatztage</th><th>Stunden gesamt</th><th>Ø Std./Tag</th><th>Anteil</th></tr></thead>
        <tbody>
          ${sorted.map(([name, d]) => {
            const pct = totalAllHours > 0 ? (d.hours/totalAllHours*100).toFixed(1) : 0;
            const barW = Math.round(d.hours/Math.max(...sorted.map(x=>x[1].hours))*100);
            return `<tr>
              <td><strong>${name}</strong></td>
              <td style="font-family:'DM Mono',monospace">${d.days} Tage</td>
              <td>
                <div style="display:flex;align-items:center;gap:10px">
                  <div style="flex:1;height:6px;background:var(--surface2);border-radius:99px;overflow:hidden">
                    <div style="width:${barW}%;height:100%;background:var(--accent);border-radius:99px"></div>
                  </div>
                  <span style="font-family:'DM Mono',monospace;font-size:0.82rem;white-space:nowrap">${d.hours.toFixed(1)} h</span>
                </div>
              </td>
              <td style="font-family:'DM Mono',monospace">${(d.hours/d.days).toFixed(1)} h</td>
              <td><span class="badge badge-yellow">${pct}%</span></td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>` : ''}

    ${monthKeys.length > 1 ? `
    <div class="chart-container">
      <div class="table-title" style="margin-bottom:16px">Arbeitsstunden pro Monat</div>
      <canvas id="diary-hours-chart" height="220"></canvas>
    </div>` : ''}

    <div class="table-wrap">
      <div class="table-header"><div class="table-title">Alle Einträge – Übersicht</div></div>
      <table>
        <thead><tr><th>Datum</th><th>Titel</th><th>Wetter</th><th>Arbeiter</th><th>Stunden</th></tr></thead>
        <tbody>
          ${[...state.tagebuch].reverse().map(e => {
            const ws = e.workers || [];
            const hrs = ws.reduce((s,w) => s+(w.hours||0), 0);
            return `<tr>
              <td style="font-family:'DM Mono',monospace;font-size:0.78rem">${fmtDate(e.datum)}</td>
              <td>${e.title}</td>
              <td>${e.weather}</td>
              <td>${ws.length ? ws.map(w=>`<span class="badge badge-gray" style="margin:1px">${w.name}</span>`).join('') : '<span style="color:var(--text3)">–</span>'}</td>
              <td style="font-family:'DM Mono',monospace">${hrs > 0 ? hrs+'h' : '–'}</td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>`;

  // draw chart after render
  if (monthKeys.length > 1) {
    setTimeout(() => {
      const canvas = document.getElementById('diary-hours-chart');
      if (canvas) {
        if (canvas._chart) canvas._chart.destroy();
        canvas._chart = new Chart(canvas, {
          type: 'bar',
          data: {
            labels: prettyMonths,
            datasets: [{
              label: 'Arbeitsstunden',
              data: monthKeys.map(k => byMonth[k]),
              backgroundColor: '#c8a96e',
              borderRadius: 6,
              borderSkipped: false
            }]
          },
          options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
              x: { ticks: { color: '#9a9284', font: { family: 'DM Mono', size: 10 } }, grid: { color: '#2e2b24' } },
              y: { ticks: { color: '#9a9284', font: { family: 'DM Mono', size: 10 }, callback: v => v+'h' }, grid: { color: '#2e2b24' } }
            }
          }
        });
      }
    }, 50);
  }
}

