          ${count > 0 ? `<div style="font-family:'DM Mono',monospace;font-size:0.65rem;color:var(--text3);margin-top:2px;margin-left:18px">${count} Buchungen – zum Öffnen klicken</div>` : `<div style="font-family:'DM Mono',monospace;font-size:0.65rem;color:var(--text3);margin-top:2px;margin-left:18px">Noch keine Buchungen</div>`}
        </td>
        <td style="font-family:'DM Mono',monospace">${fmt(kat.budget)}</td>
