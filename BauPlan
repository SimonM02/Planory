        <span>${kat.name}</span>
        ${count > 0 ? `<span style="font-family:'DM Mono',monospace;font-size:0.62rem;color:var(--text3)">${count}×</span>` : ''}
      </div>
      <div class="budget-bar-track"><div class="budget-bar-fill" style="width:${pct}%;background:${color}"></div></div>
      <div class="budget-bar-amount" style="color:${pct>90?'var(--danger)':pct>70?'var(--warning)':'var(--text2)'}">${pct}%</div>
