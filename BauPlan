const BG_COLORS = ['#3d6ff8','#7b5cfa','#0d9488','#ea6c19','#ef4444','#f59e0b','#22c55e','#e879f9','#06b6d4','#84cc16'];

function renderBudget() {
  const totalBudget = state.budgetKat.reduce((s,k) => s + k.budget, 0);
  const totalSpent  = state.kosten.filter(k => k.status !== 'Storniert').reduce((s,k) => s + (parseFloat(k.betrag)||0), 0);
  const totalRest   = totalBudget - totalSpent;
  const totalPct    = totalBudget > 0 ? Math.round(totalSpent / totalBudget * 100) : 0;

  // Ausgaben ohne zugeordnete Kategorie
  const assignedKatNames = state.budgetKat.map(k => k.name);
