    <div class="doku-card typ-${typCss}">
      <div class="doku-card-del">
        <button class="action-btn del" onclick="deleteDoku(${d.id})">🗑</button>
      </div>
      <div class="doku-card-type" style="color:${color}">${icon} ${d.typ}</div>
      <div class="doku-card-title">${d.title}</div>
      ${d.raum ? `<div style="font-family:'DM Mono',monospace;font-size:0.68rem;color:var(--text3);margin-bottom:8px;font-weight:500">📍 ${d.raum}</div>` : ''}
