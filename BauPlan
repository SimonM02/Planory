}

function updateObUI() {
  // Show/hide steps
  document.querySelectorAll('.ob-step').forEach(s => {
    s.style.display = parseInt(s.dataset.step) === obStep ? '' : 'none';
  });
  // Dots
  const dots = document.getElementById('ob-dots');
  dots.innerHTML = Array.from({length: OB_TOTAL}, (_,i) => `
    <div style="width:${i===obStep?'24px':'8px'};height:8px;border-radius:99px;background:${i===obStep?'var(--accent)':'var(--border)'};transition:all 0.3s"></div>`
  ).join('');
  // Buttons
  document.getElementById('ob-back').style.display = obStep > 0 ? '' : 'none';
  document.getElementById('ob-next').textContent = obStep === OB_TOTAL - 1 ? '🚀 Loslegen' : 'Weiter →';
}

function obNext() {
  if (obStep === 2) {
    const name = document.getElementById('ob-name').value.trim();
    if (!name) { showToast('Bitte Projektname eingeben', 'error'); return; }
  }
  if (obStep < OB_TOTAL - 1) {
    obStep++;
    updateObUI();
  } else {
    finishOnboarding();
  }
}

function obBack() {
  if (obStep > 0) { obStep--; updateObUI(); }
}

async function finishOnboarding() {
  // Build modules object
  const modules = {};
  document.querySelectorAll('#ob-module-grid input[type=checkbox]').forEach(cb => {
    modules[cb.dataset.module] = cb.checked;
  });

  // Create first project with onboarding data
  const proj = EMPTY_PROJECT();
  proj.settings.name    = document.getElementById('ob-name').value.trim() || 'Mein Projekt';
  proj.settings.type    = obType;
  proj.settings.address = document.getElementById('ob-address').value.trim();
  proj.settings.start   = document.getElementById('ob-start').value;
  proj.settings.end     = document.getElementById('ob-end').value;
  proj.settings.color   = obColor;
  proj.settings.modules = modules;

  projects = [proj];
  currentProjectId = proj.id;
  state = JSON.parse(JSON.stringify(proj));

  localStorage.setItem('bauplan_onboarded_' + currentUser?.id, '1');
  document.getElementById('onboarding-overlay').style.display = 'none';

  await syncToCloud();
  updateProjectHeader();
  applyModuleVisibility();
  renderDashboard();
  showToast(`🎉 Willkommen! "${proj.settings.name}" wurde angelegt.`, 'success');
}

