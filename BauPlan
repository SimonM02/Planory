<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>BauPlan – Mein Bauprojekt</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #eef1f8;
    --surface: #ffffff;
    --surface2: #f1f5fd;
    --surface3: #e8edf8;
    --border: #d8e2f0;
    --accent: #3d6ff8;
    --accent2: #6b91ff;
    --accent-light: #e8eeff;
    --accent-grad: linear-gradient(135deg, #3d6ff8, #7b5cfa);
    --purple: #7b5cfa;
    --purple-light: #f0ebff;
    --teal: #0d9488;
    --teal-light: #e6fafa;
    --orange: #ea6c19;
    --orange-light: #fff3ea;
    --danger: #ef4444;
    --danger-light: #fef2f2;
    --success: #16a34a;
    --success-light: #f0fdf4;
    --warning: #d97706;
    --warning-light: #fffbeb;
    --text: #0f1d30;
    --text2: #4a5e7a;
    --text3: #8ea3be;
    --shadow: 0 1px 4px rgba(30,60,120,0.07), 0 1px 2px rgba(30,60,120,0.04);
    --shadow-md: 0 6px 20px rgba(30,60,120,0.1), 0 2px 6px rgba(30,60,120,0.05);
    --shadow-lg: 0 12px 40px rgba(30,60,120,0.14);
    --radius: 14px;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    background-image: radial-gradient(circle at 20% 50%, rgba(61,111,248,0.04) 0%, transparent 50%),
                      radial-gradient(circle at 80% 20%, rgba(123,92,250,0.04) 0%, transparent 40%);
    color: var(--text);
    font-family: 'Plus Jakarta Sans', sans-serif;
    min-height: 100vh;
    display: flex;
  }

  /* SIDEBAR */
  .sidebar {
    width: 248px;
    min-height: 100vh;
    background: var(--surface);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    padding: 0;
    flex-shrink: 0;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow-y: auto;
    box-shadow: 2px 0 12px rgba(30,60,120,0.06);
  }

  .logo {
    padding: 22px 18px 18px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: center;
    gap: 12px;
    background: linear-gradient(135deg, #f8faff 0%, #f0f5ff 100%);
  }

  .logo-icon {
    width: 38px;
    height: 38px;
    background: var(--accent-grad);
    border-radius: 11px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.1rem;
    flex-shrink: 0;
    box-shadow: 0 4px 12px rgba(61,111,248,0.35);
  }

  .logo h1 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.15rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.4px;
  }

  .logo span {
    font-family: 'DM Mono', monospace;
    font-size: 0.58rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    display: block;
    margin-top: 1px;
  }

  nav { padding: 10px 10px; flex: 1; }

  .nav-section {
    font-family: 'DM Mono', monospace;
    font-size: 0.57rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 2px;
    padding: 14px 10px 5px;
    font-weight: 500;
  }

  .nav-item {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 10px;
    border-radius: 10px;
    cursor: pointer;
    color: var(--text2);
    font-size: 0.855rem;
    font-weight: 500;
    transition: all 0.15s;
    margin-bottom: 1px;
  }

  .nav-item:hover { background: var(--surface2); color: var(--text); }
  .nav-item.active {
    background: var(--accent-light);
    color: var(--accent);
    font-weight: 700;
    box-shadow: inset 3px 0 0 var(--accent);
  }
  .nav-item .icon { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }

  /* MAIN */
  .main {
    flex: 1;
    padding: 36px 40px;
    overflow-y: auto;
    max-width: 1140px;
  }

  .page { display: none; }
  .page.active { display: block; animation: fadeIn 0.2s ease; }
  @keyframes fadeIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }

  .page-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .page-header h2 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.8rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.6px;
  }

  .page-header p {
    color: var(--text3);
    font-size: 0.84rem;
    margin-top: 4px;
    font-weight: 500;
  }

  .btn {
    padding: 9px 18px;
    border-radius: 10px;
    border: none;
    cursor: pointer;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.84rem;
    font-weight: 700;
    transition: all 0.18s;
    letter-spacing: -0.1px;
  }

  .btn-primary {
    background: var(--accent-grad);
    color: white;
    box-shadow: 0 3px 10px rgba(61,111,248,0.35);
  }
  .btn-primary:hover { opacity: 0.9; box-shadow: 0 5px 16px rgba(61,111,248,0.45); transform: translateY(-1px); }
  .btn-ghost { background: white; color: var(--text2); border: 1.5px solid var(--border); }
  .btn-ghost:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
  .btn-danger { background: var(--danger); color: white; }

  /* CARDS */
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; margin-bottom: 28px; }

  .card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 22px;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
    position: relative;
    overflow: hidden;
  }

  .card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: var(--accent-grad);
    opacity: 0;
    transition: opacity 0.2s;
  }

  .card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
  .card:hover::before { opacity: 1; }

  .card-label {
    font-family: 'DM Mono', monospace;
    font-size: 0.61rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 8px;
    font-weight: 500;
  }

  .card-value {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.7rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.6px;
  }

  .card-sub {
    font-size: 0.75rem;
    color: var(--text3);
    margin-top: 5px;
    font-weight: 500;
  }

  .card-value.green { color: var(--success); }
  .card-value.red { color: var(--danger); }
  .card-value.yellow { color: var(--warning); }

  /* PROGRESS BAR */
  .progress-wrap { margin-bottom: 28px; }
  .progress-label { display: flex; justify-content: space-between; margin-bottom: 8px; font-size: 0.82rem; color: var(--text2); font-weight: 600; }
  .progress-bar { height: 10px; background: var(--surface3); border-radius: 99px; overflow: hidden; }
  .progress-fill { height: 100%; background: var(--accent-grad); border-radius: 99px; transition: width 0.6s cubic-bezier(.34,1.56,.64,1); }

  /* TABLE */
  .table-wrap {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }

  .table-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px;
    border-bottom: 1.5px solid var(--border);
    background: linear-gradient(to right, #fafcff, #f6f9ff);
  }

  .table-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.98rem;
    font-weight: 700;
    color: var(--text);
  }

  table { width: 100%; border-collapse: collapse; }

  th {
    font-family: 'DM Mono', monospace;
    font-size: 0.59rem;
    color: var(--text3);
    text-transform: uppercase;
    letter-spacing: 1.5px;
    padding: 10px 20px;
    text-align: left;
    border-bottom: 1.5px solid var(--border);
    background: var(--surface2);
    font-weight: 500;
  }

  td {
    padding: 13px 20px;
    font-size: 0.875rem;
    color: var(--text);
    border-bottom: 1px solid var(--border);
  }

  tr:last-child td { border-bottom: none; }
  tr:hover td { background: #f6f9ff; }

  .badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 99px;
    font-size: 0.7rem;
    font-weight: 700;
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .badge-green { background: var(--success-light); color: var(--success); }
  .badge-red { background: var(--danger-light); color: var(--danger); }
  .badge-yellow { background: var(--warning-light); color: var(--warning); }
  .badge-blue { background: #eff6ff; color: #2563eb; }
  .badge-gray { background: var(--surface2); color: var(--text2); }
  .badge-purple { background: var(--purple-light); color: var(--purple); }
  .badge-teal { background: var(--teal-light); color: var(--teal); }
  .badge-orange { background: var(--orange-light); color: var(--orange); }

  .action-btn {
    background: none;
    border: none;
    cursor: pointer;
    color: var(--text3);
    padding: 5px 7px;
    border-radius: 7px;
    font-size: 0.9rem;
    transition: all 0.15s;
  }

  .action-btn:hover { color: var(--accent); background: var(--accent-light); }
  .action-btn.del:hover { color: var(--danger); background: var(--danger-light); }

  /* MODAL */
  .modal-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15,29,48,0.45);
    backdrop-filter: blur(6px);
    z-index: 100;
    align-items: center;
    justify-content: center;
  }

  .modal-overlay.open { display: flex; }

  .modal {
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 18px;
    padding: 30px;
    width: 500px;
    max-width: 96vw;
    max-height: 88vh;
    overflow-y: auto;
    box-shadow: var(--shadow-lg);
    animation: modalIn 0.22s cubic-bezier(.34,1.56,.64,1);
  }

  @keyframes modalIn { from { opacity:0; transform:scale(0.96) translateY(8px); } to { opacity:1; transform:none; } }

  .modal h3 {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.2rem;
    font-weight: 800;
    margin-bottom: 20px;
    color: var(--text);
    letter-spacing: -0.3px;
  }

  .form-row { margin-bottom: 14px; }
  .form-row label { display: block; font-size: 0.72rem; color: var(--text2); margin-bottom: 5px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; }
  .form-row input, .form-row select, .form-row textarea {
    width: 100%;
    background: var(--surface2);
    border: 1.5px solid var(--border);
    border-radius: 9px;
    color: var(--text);
    padding: 9px 13px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s, background 0.15s;
    font-weight: 500;
  }

  .form-row input:focus, .form-row select:focus, .form-row textarea:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 3px rgba(61,111,248,0.12);
    background: white;
  }
  .form-row textarea { resize: vertical; min-height: 80px; }
  .form-row select option { background: white; }
  .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }

  /* CHART */
  .chart-container {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }
  .chart-container canvas { max-height: 280px; }

  .chart-tabs { display: flex; gap: 6px; margin-bottom: 20px; flex-wrap: wrap; }
  .chart-tab {
    padding: 7px 16px;
    border-radius: 9px;
    border: 1.5px solid var(--border);
    background: white;
    color: var(--text2);
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.8rem;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.15s;
  }
  .chart-tab:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
  .chart-tab.active { background: var(--accent-grad); color: white; border-color: transparent; box-shadow: 0 3px 10px rgba(61,111,248,0.3); }

  /* SEARCH */
  .search-bar {
    background: white;
    border: 1.5px solid var(--border);
    border-radius: 9px;
    color: var(--text);
    padding: 8px 14px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.85rem;
    outline: none;
    width: 200px;
    transition: border-color 0.15s, box-shadow 0.15s;
    font-weight: 500;
  }
  .search-bar:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(61,111,248,0.1); }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

  /* DIARY */
  .diary-entry {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 22px;
    margin-bottom: 14px;
    position: relative;
    box-shadow: var(--shadow);
    transition: box-shadow 0.2s, transform 0.2s;
  }
  .diary-entry:hover { box-shadow: var(--shadow-md); transform: translateY(-1px); }
  .diary-date { font-family: 'DM Mono', monospace; font-size: 0.7rem; color: var(--accent); margin-bottom: 6px; letter-spacing: 0.5px; font-weight: 500; }
  .diary-title { font-size: 1.05rem; font-weight: 700; margin-bottom: 8px; color: var(--text); }
  .diary-text { font-size: 0.875rem; color: var(--text2); line-height: 1.65; }
  .diary-tags { margin-top: 12px; display: flex; gap: 6px; flex-wrap: wrap; }
  .diary-actions { position: absolute; top: 16px; right: 16px; display: flex; gap: 4px; }

  /* MILESTONES */
  .milestone-list { display: flex; flex-direction: column; gap: 10px; }
  .milestone-item {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: var(--shadow);
    transition: all 0.2s;
  }
  .milestone-item:hover { box-shadow: var(--shadow-md); transform: translateX(2px); }
  .milestone-check {
    width: 26px; height: 26px; border-radius: 50%;
    border: 2px solid var(--border);
    cursor: pointer; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    font-size: 0.8rem; transition: all 0.15s; background: white;
  }
  .milestone-check:hover { border-color: var(--accent); background: var(--accent-light); }
  .milestone-check.done { background: var(--success); border-color: var(--success); color: white; }
  .milestone-info { flex: 1; }
  .milestone-name { font-size: 0.92rem; font-weight: 600; color: var(--text); }
  .milestone-name.done { text-decoration: line-through; color: var(--text3); }
  .milestone-date { font-family: 'DM Mono', monospace; font-size: 0.68rem; color: var(--text3); margin-top: 3px; }

  /* BUDGET */
  .budget-visual {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }
  .budget-bars { display: flex; flex-direction: column; gap: 12px; margin-top: 16px; }
  .budget-bar-row { display: flex; align-items: center; gap: 12px; }
  .budget-bar-label { width: 130px; font-size: 0.82rem; color: var(--text2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 600; }
  .budget-bar-track { flex: 1; height: 10px; background: var(--surface3); border-radius: 99px; overflow: hidden; }
  .budget-bar-fill { height: 100%; border-radius: 99px; transition: width 0.5s cubic-bezier(.34,1.56,.64,1); }
  .budget-bar-amount { width: 80px; text-align: right; font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--text2); }

  /* EMPTY */
  .empty { text-align: center; padding: 48px 20px; color: var(--text3); }
  .empty .icon { font-size: 2.8rem; margin-bottom: 12px; }
  .empty p { font-size: 0.875rem; color: var(--text3); font-weight: 500; }

  /* GANTT */
  .gantt-wrap { background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 20px; box-shadow: var(--shadow); }
  .gantt-scroll { overflow-x: auto; }
  .gantt-grid { display: grid; min-width: 800px; }
  .gantt-header-row { display: flex; border-bottom: 1.5px solid var(--border); background: var(--surface2); }
  .gantt-label-col { width: 200px; flex-shrink: 0; padding: 10px 16px; font-family: 'DM Mono', monospace; font-size: 0.59rem; color: var(--text3); text-transform: uppercase; letter-spacing: 1.5px; border-right: 1.5px solid var(--border); }
  .gantt-month-headers { flex: 1; display: flex; }
  .gantt-month-header { flex: 1; text-align: center; padding: 10px 4px; font-family: 'DM Mono', monospace; font-size: 0.62rem; color: var(--text2); border-right: 1px solid var(--border); font-weight: 500; }
  .gantt-row { display: flex; border-bottom: 1px solid var(--border); align-items: center; min-height: 46px; }
  .gantt-row:last-child { border-bottom: none; }
  .gantt-row:hover { background: #f6f9ff; }
  .gantt-row-label { width: 200px; flex-shrink: 0; padding: 10px 16px; font-size: 0.84rem; border-right: 1.5px solid var(--border); display: flex; flex-direction: column; gap: 2px; }
  .gantt-row-label small { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--text3); }
  .gantt-timeline { flex: 1; position: relative; height: 46px; }
  .gantt-bar { position: absolute; top: 50%; transform: translateY(-50%); height: 24px; border-radius: 7px; display: flex; align-items: center; padding: 0 9px; font-size: 0.7rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; cursor: default; transition: opacity 0.15s; min-width: 8px; box-shadow: 0 2px 6px rgba(0,0,0,0.12); }
  .gantt-bar:hover { opacity: 0.85; }

  /* FOTO */
  .photo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 14px; }
  .photo-card { background: var(--surface); border: 1.5px solid var(--border); border-radius: var(--radius); overflow: hidden; position: relative; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; box-shadow: var(--shadow); }
  .photo-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--accent); }
  .photo-card img { width: 100%; height: 150px; object-fit: cover; display: block; }
  .photo-card-info { padding: 10px 12px; }
  .photo-card-title { font-size: 0.85rem; font-weight: 700; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text); }
  .photo-card-meta { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--text3); margin-top: 3px; }
  .photo-card-del { position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.92); border: none; color: var(--danger); border-radius: 6px; padding: 4px 7px; cursor: pointer; font-size: 0.8rem; opacity: 0; transition: opacity 0.15s; }
  .photo-card:hover .photo-card-del { opacity: 1; }
  .photo-upload-area { border: 2px dashed var(--border); border-radius: var(--radius); padding: 36px; text-align: center; cursor: pointer; transition: all 0.18s; margin-bottom: 20px; background: white; }
  .photo-upload-area:hover { border-color: var(--accent); background: var(--accent-light); }
  .photo-upload-area .icon { font-size: 2.2rem; margin-bottom: 10px; }
  .photo-upload-area p { font-size: 0.875rem; color: var(--text2); font-weight: 600; }
  .photo-upload-area small { font-size: 0.75rem; color: var(--text3); }

  /* LIGHTBOX */
  .lightbox { display: none; position: fixed; inset: 0; background: rgba(10,18,35,0.92); backdrop-filter: blur(10px); z-index: 200; align-items: center; justify-content: center; flex-direction: column; }
  .lightbox.open { display: flex; }
  .lightbox img { max-width: 90vw; max-height: 80vh; border-radius: 14px; object-fit: contain; box-shadow: 0 24px 80px rgba(0,0,0,0.5); }
  .lightbox-info { margin-top: 16px; text-align: center; }
  .lightbox-info strong { font-size: 1rem; color: white; font-weight: 700; }
  .lightbox-info small { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: rgba(255,255,255,0.4); margin-left: 10px; }
  .lightbox-close { position: absolute; top: 20px; right: 24px; background: rgba(255,255,255,0.12); border: none; color: white; font-size: 1.1rem; cursor: pointer; padding: 9px 13px; border-radius: 9px; font-weight: 700; }
  .lightbox-close:hover { background: rgba(255,255,255,0.22); }

  /* SIDEBAR FOOTER */
  .sidebar-footer { padding: 14px 18px; border-top: 1px solid var(--border); font-family: 'DM Mono', monospace; font-size: 0.61rem; color: var(--text3); }

  /* ── DOKUMENTATION & WARTUNG ── */
  .doku-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; }

  .doku-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    box-shadow: var(--shadow);
    position: relative;
    transition: all 0.2s;
    overflow: hidden;
  }

  .doku-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    border-radius: 4px 0 0 4px;
  }

  .doku-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }

  .doku-card.typ-elektro::before { background: #f59e0b; }
  .doku-card.typ-wasser::before { background: #0ea5e9; }
  .doku-card.typ-heizung::before { background: #ef4444; }
  .doku-card.typ-statik::before { background: #8b5cf6; }
  .doku-card.typ-sonstiges::before { background: #64748b; }

  .doku-card-type {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    margin-bottom: 6px;
    font-weight: 600;
  }

  .doku-card-title { font-size: 0.95rem; font-weight: 700; color: var(--text); margin-bottom: 8px; }
  .doku-card-text { font-size: 0.84rem; color: var(--text2); line-height: 1.6; }
  .doku-card-meta { margin-top: 12px; display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .doku-card-del { position: absolute; top: 12px; right: 12px; }

  /* WARTUNGSPLAN */
  .wartung-item {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: var(--radius);
    padding: 18px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: var(--shadow);
    margin-bottom: 10px;
    transition: all 0.2s;
    position: relative;
  }

  .wartung-item:hover { box-shadow: var(--shadow-md); }

  .wartung-icon {
    width: 44px; height: 44px;
    border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    font-size: 1.3rem;
    flex-shrink: 0;
  }

  .wartung-info { flex: 1; }
  .wartung-name { font-size: 0.94rem; font-weight: 700; color: var(--text); margin-bottom: 3px; }
  .wartung-desc { font-size: 0.8rem; color: var(--text2); }
  .wartung-next { font-family: 'DM Mono', monospace; font-size: 0.7rem; margin-top: 5px; font-weight: 600; }
  .wartung-next.overdue { color: var(--danger); }
  .wartung-next.soon { color: var(--warning); }
  .wartung-next.ok { color: var(--success); }

  .wartung-interval {
    text-align: center;
    flex-shrink: 0;
    width: 80px;
  }

  .wartung-interval-val {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--accent);
  }

  .wartung-interval-unit {
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: var(--text3);
    text-transform: uppercase;
  }

  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
  @keyframes slideUp { from { opacity:0; transform: translateY(12px); } to { opacity:1; transform: none; } }

  @media (max-width: 700px) {
    .sidebar { width: 62px; }
    .nav-item span, .logo h1, .logo span, .logo-icon + div, .sidebar-footer, .nav-section { display: none; }
    .logo { justify-content: center; padding: 16px 0; }
    .main { padding: 20px 16px; }
    .two-col { grid-template-columns: 1fr; }
    .cards-grid { grid-template-columns: 1fr 1fr; }
  }

  /* DIARY */
  .diary-entry {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 20px;
    margin-bottom: 14px;
    position: relative;
    box-shadow: var(--shadow);
    transition: box-shadow 0.15s;
  }

  .diary-entry:hover { box-shadow: var(--shadow-md); }

  .diary-date {
    font-family: 'DM Mono', monospace;
    font-size: 0.7rem;
    color: var(--accent);
    margin-bottom: 6px;
    letter-spacing: 0.5px;
    font-weight: 500;
  }

  .diary-title {
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 1.05rem;
    font-weight: 700;
    margin-bottom: 8px;
    color: var(--text);
  }

  .diary-text { font-size: 0.875rem; color: var(--text2); line-height: 1.65; }

  .diary-tags { margin-top: 12px; display: flex; gap: 6px; flex-wrap: wrap; }

  .diary-actions { position: absolute; top: 16px; right: 16px; display: flex; gap: 4px; }

  /* MILESTONES */
  .milestone-list { display: flex; flex-direction: column; gap: 10px; }

  .milestone-item {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 16px 20px;
    display: flex;
    align-items: center;
    gap: 16px;
    box-shadow: var(--shadow);
    transition: box-shadow 0.15s;
  }

  .milestone-item:hover { box-shadow: var(--shadow-md); }

  .milestone-check {
    width: 26px;
    height: 26px;
    border-radius: 50%;
    border: 2px solid var(--border);
    cursor: pointer;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.8rem;
    transition: all 0.15s;
    background: white;
  }

  .milestone-check:hover { border-color: var(--accent); background: var(--accent-light); }
  .milestone-check.done { background: var(--success); border-color: var(--success); color: white; }

  .milestone-info { flex: 1; }
  .milestone-name { font-size: 0.92rem; font-weight: 600; color: var(--text); }
  .milestone-name.done { text-decoration: line-through; color: var(--text3); }
  .milestone-date { font-family: 'DM Mono', monospace; font-size: 0.68rem; color: var(--text3); margin-top: 3px; }

  /* BUDGET CHART */
  .budget-visual {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }

  .budget-bars { display: flex; flex-direction: column; gap: 12px; margin-top: 16px; }

  .budget-bar-row { display: flex; align-items: center; gap: 12px; }
  .budget-bar-label { width: 130px; font-size: 0.82rem; color: var(--text2); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: 500; }
  .budget-bar-track { flex: 1; height: 10px; background: var(--surface2); border-radius: 99px; overflow: hidden; }
  .budget-bar-fill { height: 100%; border-radius: 99px; transition: width 0.4s; }
  .budget-bar-amount { width: 80px; text-align: right; font-family: 'DM Mono', monospace; font-size: 0.72rem; color: var(--text2); }

  /* EMPTY STATE */
  .empty {
    text-align: center;
    padding: 40px 20px;
    color: var(--text3);
  }

  .empty .icon { font-size: 2.5rem; margin-bottom: 12px; }
  .empty p { font-size: 0.875rem; color: var(--text3); }

  /* SEARCH */
  .search-bar {
    background: var(--surface2);
    border: 1.5px solid var(--border);
    border-radius: 9px;
    color: var(--text);
    padding: 8px 14px;
    font-family: 'Plus Jakarta Sans', sans-serif;
    font-size: 0.85rem;
    outline: none;
    width: 200px;
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .search-bar:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(79,126,248,0.12); background: white; }

  .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }

  /* GANTT */
  .gantt-wrap {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    overflow: hidden;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }

  .gantt-scroll { overflow-x: auto; }
  .gantt-grid { display: grid; min-width: 800px; }

  .gantt-header-row {
    display: flex;
    border-bottom: 1.5px solid var(--border);
    background: var(--surface2);
  }

  .gantt-label-col { width: 200px; flex-shrink: 0; padding: 10px 16px; font-family: 'DM Mono', monospace; font-size: 0.6rem; color: var(--text3); text-transform: uppercase; letter-spacing: 1.5px; border-right: 1.5px solid var(--border); }

  .gantt-month-headers { flex: 1; display: flex; }
  .gantt-month-header { flex: 1; text-align: center; padding: 10px 4px; font-family: 'DM Mono', monospace; font-size: 0.62rem; color: var(--text2); border-right: 1px solid var(--border); font-weight: 500; }

  .gantt-row {
    display: flex;
    border-bottom: 1px solid var(--border);
    align-items: center;
    min-height: 44px;
  }

  .gantt-row:last-child { border-bottom: none; }
  .gantt-row:hover { background: #f8faff; }

  .gantt-row-label {
    width: 200px;
    flex-shrink: 0;
    padding: 10px 16px;
    font-size: 0.84rem;
    border-right: 1.5px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .gantt-row-label small { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--text3); }

  .gantt-timeline { flex: 1; position: relative; height: 44px; }

  .gantt-bar {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    height: 22px;
    border-radius: 6px;
    display: flex;
    align-items: center;
    padding: 0 8px;
    font-size: 0.7rem;
    font-weight: 600;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    cursor: default;
    transition: opacity 0.15s;
    min-width: 8px;
  }

  .gantt-bar:hover { opacity: 0.85; }

  /* FOTO GALERIE */
  .photo-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 14px; }

  .photo-card {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    position: relative;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    box-shadow: var(--shadow);
  }

  .photo-card:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); border-color: var(--accent); }

  .photo-card img { width: 100%; height: 150px; object-fit: cover; display: block; }

  .photo-card-info { padding: 10px 12px; }
  .photo-card-title { font-size: 0.85rem; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; color: var(--text); }
  .photo-card-meta { font-family: 'DM Mono', monospace; font-size: 0.65rem; color: var(--text3); margin-top: 3px; }

  .photo-card-del { position: absolute; top: 8px; right: 8px; background: rgba(255,255,255,0.9); border: none; color: var(--danger); border-radius: 6px; padding: 4px 7px; cursor: pointer; font-size: 0.8rem; opacity: 0; transition: opacity 0.15s; }
  .photo-card:hover .photo-card-del { opacity: 1; }

  .photo-upload-area {
    border: 2px dashed var(--border);
    border-radius: 14px;
    padding: 32px;
    text-align: center;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s;
    margin-bottom: 20px;
    background: white;
  }

  .photo-upload-area:hover { border-color: var(--accent); background: var(--accent-light); }
  .photo-upload-area .icon { font-size: 2rem; margin-bottom: 8px; }
  .photo-upload-area p { font-size: 0.875rem; color: var(--text2); font-weight: 500; }
  .photo-upload-area small { font-size: 0.75rem; color: var(--text3); }

  /* LIGHTBOX */
  .lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(15,20,35,0.88);
    backdrop-filter: blur(8px);
    z-index: 200;
    align-items: center;
    justify-content: center;
    flex-direction: column;
  }

  .lightbox.open { display: flex; }
  .lightbox img { max-width: 90vw; max-height: 80vh; border-radius: 12px; object-fit: contain; box-shadow: 0 24px 80px rgba(0,0,0,0.5); }
  .lightbox-info { margin-top: 16px; text-align: center; }
  .lightbox-info strong { font-size: 1rem; color: white; }
  .lightbox-info small { font-family: 'DM Mono', monospace; font-size: 0.72rem; color: rgba(255,255,255,0.5); margin-left: 10px; }
  .lightbox-close { position: absolute; top: 20px; right: 24px; background: rgba(255,255,255,0.15); border: none; color: white; font-size: 1.2rem; cursor: pointer; padding: 8px 12px; border-radius: 8px; }
  .lightbox-close:hover { background: rgba(255,255,255,0.25); }

  /* COST CHART */
  .chart-container {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 14px;
    padding: 24px;
    margin-bottom: 20px;
    box-shadow: var(--shadow);
  }

  .chart-container canvas { max-height: 280px; }

  .chart-tabs { display: flex; gap: 6px; margin-bottom: 20px; }
  .chart-tab { padding: 7px 16px; border-radius: 8px; border: 1.5px solid var(--border); background: white; color: var(--text2); font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.8rem; font-weight: 600; cursor: pointer; transition: all 0.15s; }
  .chart-tab:hover { border-color: var(--accent); color: var(--accent); background: var(--accent-light); }
  .chart-tab.active { background: var(--accent); color: white; border-color: var(--accent); box-shadow: 0 2px 8px rgba(79,126,248,0.3); }

  .sidebar-footer {
    padding: 16px 20px;
    border-top: 1px solid var(--border);
    font-family: 'DM Mono', monospace;
    font-size: 0.62rem;
    color: var(--text3);
  }

</style>
<!-- Supabase -->
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>

<!-- ══════════════════════════════════════
     AUTH OVERLAY (Login / Register)
══════════════════════════════════════ -->
<div id="auth-overlay" style="display:none;position:fixed;inset:0;z-index:1000;background:var(--bg);align-items:center;justify-content:center">
  <div style="width:100%;max-width:420px;padding:24px">

    <!-- Logo -->
    <div style="text-align:center;margin-bottom:32px">
      <div style="width:64px;height:64px;background:var(--accent-grad);border-radius:18px;display:inline-flex;align-items:center;justify-content:center;font-size:2rem;margin-bottom:14px;box-shadow:0 8px 24px rgba(61,111,248,0.3)">🏗️</div>
      <h1 style="font-size:1.8rem;font-weight:800;color:var(--text);letter-spacing:-0.5px">BauPlan</h1>
      <p style="color:var(--text3);font-size:0.85rem;margin-top:4px">Dein smarter Bauprojekt-Manager</p>
    </div>

    <!-- Tabs -->
    <div style="display:flex;background:var(--surface2);border-radius:10px;padding:4px;margin-bottom:24px">
      <button id="auth-tab-login" onclick="switchAuthTab('login')"
        style="flex:1;padding:8px;border-radius:7px;border:none;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.85rem;font-weight:700;cursor:pointer;background:white;color:var(--text);box-shadow:var(--shadow);transition:all 0.15s">
        Anmelden
      </button>
      <button id="auth-tab-register" onclick="switchAuthTab('register')"
        style="flex:1;padding:8px;border-radius:7px;border:none;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.85rem;font-weight:600;cursor:pointer;background:transparent;color:var(--text2);transition:all 0.15s">
        Registrieren
      </button>
    </div>

    <!-- Form Card -->
    <div style="background:white;border-radius:16px;padding:24px;box-shadow:var(--shadow-md);border:1.5px solid var(--border)">

      <!-- Login Form -->
      <div id="auth-form-login">
        <div class="form-row" style="margin-bottom:14px">
          <label>E-Mail</label>
          <input type="email" id="auth-email" placeholder="deine@email.at" onkeydown="if(event.key==='Enter')doLogin()">
        </div>
        <div class="form-row" style="margin-bottom:6px">
          <label>Passwort</label>
          <input type="password" id="auth-password" placeholder="••••••••" onkeydown="if(event.key==='Enter')doLogin()">
        </div>
        <div style="text-align:right;margin-bottom:18px">
          <span onclick="showForgotPassword()" style="font-size:0.78rem;color:var(--accent);cursor:pointer;font-weight:600">Passwort vergessen?</span>
        </div>
        <button onclick="doLogin()" id="btn-login"
          style="width:100%;background:var(--accent-grad);color:white;border:none;padding:12px;border-radius:10px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.9rem;font-weight:700;cursor:pointer;box-shadow:0 3px 10px rgba(61,111,248,0.3)">
          Anmelden
        </button>
      </div>

      <!-- Register Form -->
      <div id="auth-form-register" style="display:none">
        <div class="form-row" style="margin-bottom:14px">
          <label>E-Mail</label>
          <input type="email" id="reg-email" placeholder="deine@email.at">
        </div>
        <div class="form-row" style="margin-bottom:14px">
          <label>Passwort</label>
          <input type="password" id="reg-password" placeholder="Mindestens 6 Zeichen">
        </div>
        <div class="form-row" style="margin-bottom:18px">
          <label>Passwort wiederholen</label>
          <input type="password" id="reg-password2" placeholder="••••••••" onkeydown="if(event.key==='Enter')doRegister()">
        </div>
        <button onclick="doRegister()" id="btn-register"
          style="width:100%;background:var(--accent-grad);color:white;border:none;padding:12px;border-radius:10px;font-family:'Plus Jakarta Sans',sans-serif;font-size:0.9rem;font-weight:700;cursor:pointer;box-shadow:0 3px 10px rgba(61,111,248,0.3)">
          Konto erstellen
        </button>
      </div>

      <!-- Error/Info message -->
      <div id="auth-msg" style="display:none;margin-top:14px;padding:10px 14px;border-radius:9px;font-size:0.83rem;font-weight:600;text-align:center"></div>
    </div>

    <p style="text-align:center;font-size:0.75rem;color:var(--text3);margin-top:20px;line-height:1.5">
      Deine Daten werden sicher gespeichert.<br>Keine Weitergabe an Dritte.
    </p>
  </div>
</div>

<!-- ══════════════════════════════════════
     ONBOARDING OVERLAY
══════════════════════════════════════ -->
<div id="onboarding-overlay" style="display:none;position:fixed;inset:0;z-index:999;background:var(--bg);overflow-y:auto">
  <div style="max-width:560px;margin:0 auto;padding:40px 24px">

    <!-- Progress dots -->
    <div style="display:flex;justify-content:center;gap:8px;margin-bottom:36px" id="ob-dots"></div>

    <!-- Steps container -->
    <div id="ob-steps">

      <!-- Step 1: Willkommen -->
      <div class="ob-step" data-step="0">
        <div style="text-align:center;margin-bottom:32px">
          <div style="font-size:4rem;margin-bottom:16px">👋</div>
          <h2 style="font-size:1.8rem;font-weight:800;color:var(--text);letter-spacing:-0.5px;margin-bottom:12px">Willkommen bei BauPlan!</h2>
          <p style="color:var(--text2);line-height:1.7;font-size:0.92rem">Dein smarter Begleiter für Bauprojekte. Budgets, Kosten, Tagebuch, Dokumentation und KI-Bauberatung – alles an einem Ort.</p>
        </div>
        <div style="display:flex;flex-direction:column;gap:12px;margin-bottom:32px">
          ${[['💶','Kosten & Budget verwalten','Rechnungen scannen, Budgets planen'],
             ['🤖','KI-Bauberater','Automatische Analyse & Warnungen'],
             ['📓','Bautagebuch','Fortschritt dokumentieren'],
             ['🔧','Wartungsplan','Nie wieder einen Termin vergessen']
            ].map(([icon,title,sub])=>`
          <div style="display:flex;gap:14px;align-items:center;background:white;border-radius:12px;padding:14px 16px;border:1.5px solid var(--border);box-shadow:var(--shadow)">
            <span style="font-size:1.5rem;flex-shrink:0">${icon}</span>
            <div><div style="font-weight:700;font-size:0.88rem;color:var(--text)">${title}</div><div style="font-size:0.78rem;color:var(--text3)">${sub}</div></div>
          </div>`).join('')}
        </div>
      </div>

      <!-- Step 2: Projekttyp -->
      <div class="ob-step" data-step="1" style="display:none">
        <h2 style="font-size:1.6rem;font-weight:800;color:var(--text);margin-bottom:8px">Was planst du?</h2>
        <p style="color:var(--text3);margin-bottom:24px;font-size:0.88rem">Wähle die Art deines Projekts – du kannst das später ändern.</p>
        <div style="display:flex;flex-direction:column;gap:10px" id="ob-type-picker">
          ${[['🏠','Neubau','Haus oder Wohnung neu bauen'],
             ['🔨','Umbau / Erweiterung','Bestehendes erweitern oder umbauen'],
             ['🔧','Sanierung / Renovierung','Modernisieren und instand setzen'],
             ['📋','Sonstiges','Anderes Bauprojekt']
            ].map(([icon,label,sub],i)=>`
          <div onclick="selectObType('${label}',this)"
            style="display:flex;gap:14px;align-items:center;background:white;border-radius:12px;padding:16px;border:2px solid var(--border);cursor:pointer;transition:all 0.15s"
            onmouseover="this.style.borderColor='var(--accent)'" onmouseout="if(!this.classList.contains('ob-selected'))this.style.borderColor='var(--border)'">
            <span style="font-size:1.6rem;flex-shrink:0">${icon}</span>
            <div><div style="font-weight:700;color:var(--text)">${label}</div><div style="font-size:0.78rem;color:var(--text3)">${sub}</div></div>
          </div>`).join('')}
        </div>
      </div>

      <!-- Step 3: Projektdetails -->
      <div class="ob-step" data-step="2" style="display:none">
        <h2 style="font-size:1.6rem;font-weight:800;color:var(--text);margin-bottom:8px">Dein Projekt</h2>
        <p style="color:var(--text3);margin-bottom:24px;font-size:0.88rem">Grundlegende Infos – alles kann später bearbeitet werden.</p>
        <div style="display:flex;flex-direction:column;gap:14px">
          <div class="form-row"><label>Projektname *</label><input type="text" id="ob-name" placeholder="z.B. Einfamilienhaus Musterhausen"></div>
