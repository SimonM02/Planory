}

function deleteEigenleistung(id) {
  if (!confirm('Eigenleistung löschen?')) return;
  state.eigenleistungen = (state.eigenleistungen||[]).filter(e => e.id !== id);
  save(); renderKosten();
}

function renderKosten() {
  state.eigenleistungen = state.eigenleistungen || [];
  const search = (document.getElementById('kosten-search')?.value || '').toLowerCase();
  const items = state.kosten.filter(k =>
    k.beschr.toLowerCase().includes(search) || k.kat.toLowerCase().includes(search) || (k.anbieter||'').toLowerCase().includes(search)
  );

  const paid = state.kosten.filter(k => k.status !== 'Storniert');
  const totalBrutto = paid.reduce((s,k) => s + (parseFloat(k.betrag)||0), 0);
  const totalNetto  = paid.reduce((s,k) => s + (parseFloat(k.netto ?? k.betrag)||0), 0);
  const totalMwst   = totalBrutto - totalNetto;
  const totalEigen  = state.eigenleistungen.reduce((s,e) => s + (parseFloat(e.wert)||0), 0);

  const now = new Date(); const month = now.getMonth(); const year = now.getFullYear();
  const monthTotal = paid.filter(k => {
    const d = new Date(k.datum); return d.getMonth()===month && d.getFullYear()===year;
  }).reduce((s,k) => s + (parseFloat(k.betrag)||0), 0);

  document.getElementById('k-total').textContent = fmt(totalBrutto);
  document.getElementById('k-netto').textContent = fmt(totalNetto);
  document.getElementById('k-mwst-info').textContent = `MwSt: ${fmt(totalMwst)}`;
  document.getElementById('k-month').textContent = fmt(monthTotal);
  document.getElementById('k-eigen').textContent = fmt(totalEigen);

  // Ausgaben table
  const tbody = document.getElementById('kosten-table');
  if (items.length === 0) {
    tbody.innerHTML = `<tr><td colspan="8"><div class="empty"><div class="icon">💶</div><p>Noch keine Ausgaben erfasst</p></div></td></tr>`;
  } else {
    tbody.innerHTML = [...items].reverse().map(k => {
      const netto = k.netto ?? k.betrag;
      const mwstBetrag = k.betrag - netto;
      const mwstLabel = k.mwst > 0 ? `<span class="badge badge-yellow" style="font-size:0.65rem">${k.mwst}%</span>` : `<span class="badge badge-gray" style="font-size:0.65rem">0%</span>`;
      return `<tr>
        <td style="font-family:'DM Mono',monospace;font-size:0.78rem">${fmtDate(k.datum)}</td>
        <td><span class="badge badge-gray">${k.kat}</span></td>
        <td>${k.beschr}${k.anbieter?`<br><span style="font-size:0.75rem;color:var(--text3)">${k.anbieter}</span>`:''}${k.aiScanned?`<span class="badge badge-purple" style="margin-left:6px;font-size:0.6rem">🤖 KI</span>`:''}</td>
        <td style="font-family:'DM Mono',monospace;font-size:0.82rem">${fmt(netto)}</td>
        <td style="font-family:'DM Mono',monospace;font-size:0.78rem;color:var(--text3)">${mwstBetrag > 0 ? fmt(mwstBetrag) : '–'} ${mwstLabel}</td>
        <td style="font-family:'DM Mono',monospace;font-weight:600">${fmt(k.betrag)}</td>
        <td><span class="badge ${k.status==='Bezahlt'?'badge-green':k.status==='Ausstehend'?'badge-yellow':'badge-red'}">${k.status}</span></td>
        <td style="display:flex;gap:4px">
          <button class="action-btn" onclick="editKosten(${k.id})" title="Bearbeiten">✏️</button>
          <button class="action-btn del" onclick="deleteKosten(${k.id})" title="Löschen">🗑</button>
        </td>
      </tr>`;
    }).join('');
  }

  // Eigenleistungen table
  const etbody = document.getElementById('eigen-table');
  if (state.eigenleistungen.length === 0) {
    etbody.innerHTML = `<tr><td colspan="6"><div class="empty"><div class="icon">🤝</div><p>Noch keine Eigenleistungen erfasst</p></div></td></tr>`;
  } else {
    etbody.innerHTML = [...state.eigenleistungen].reverse().map(e => `
      <tr>
        <td style="font-family:'DM Mono',monospace;font-size:0.78rem">${fmtDate(e.datum)}</td>
        <td><span class="badge badge-gray">${e.kat}</span></td>
        <td>
          ${e.beschr}
          ${e.notiz ? `<br><span style="font-size:0.75rem;color:var(--text3)">${e.notiz}</span>` : ''}
        </td>
        <td style="font-family:'DM Mono',monospace;font-weight:600;color:var(--success)">${fmt(e.wert)}</td>
        <td>${e.von || '–'}</td>
        <td><button class="action-btn del" onclick="deleteEigenleistung(${e.id})">🗑</button></td>
      </tr>`).join('');
  }
}

