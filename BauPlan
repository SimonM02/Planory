let addPhotoToDokuId = null;
function openAddPhotoToDoku(id) {
  addPhotoToDokuId = id;
  const inp = document.getElementById('doku-add-photo-input');
  if (inp) inp.click();
}
function handleAddDokuPhoto(input) {
  const d = (state.dokumentation || []).find(x => x.id === addPhotoToDokuId);
  if (!d) return;
  d.fotos = d.fotos || [];
  const files = Array.from(input.files);
  let loaded = 0;
  files.forEach(file => {
    const reader = new FileReader();
    reader.onload = e => {
      d.fotos.push({ data: e.target.result, name: file.name });
      loaded++;
      if (loaded === files.length) { save(); renderDoku(); }
    };
    reader.readAsDataURL(file);
  });
  input.value = '';
}
function openDokuLightbox(dokuId, photoIdx) {
  const d = (state.dokumentation || []).find(x => x.id === dokuId);
  if (!d || !d.fotos) return;
  const f = d.fotos[photoIdx];
  document.getElementById('lightbox-img').src = f.data;
  document.getElementById('lightbox-title').textContent = d.title;
  document.getElementById('lightbox-meta').textContent = `${d.typ} · ${d.raum || ''} · Foto ${photoIdx+1}/${d.fotos.length}`;
  document.getElementById('lightbox').classList.add('open');
}

