async function askKI() {
  const question = document.getElementById('ki-chat-input').value.trim();
  if (!question) return;

  const btn = document.getElementById('ki-ask-btn');
  btn.disabled = true;
  btn.textContent = '…';

  const answerEl = document.getElementById('ki-chat-answer');
  answerEl.style.display = 'block';
  answerEl.innerHTML = `<span style="color:var(--text3);font-style:italic">KI denkt nach…</span>`;

  const snapshot = buildProjectSnapshot();

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 800,
        system: `Du bist ein erfahrener KI-Bauberater. Antworte auf die Frage des Bauherrn auf Deutsch, konkret und hilfreich. Nutze die Projektdaten. Antwort max. 3-4 Sätze, kein JSON, kein Markdown.`,
        messages: [{
          role: 'user',
          content: `Projektdaten:\n${JSON.stringify(snapshot)}\n\nFrage: ${question}`
        }]
      })
    });

    const data = await resp.json();
    const answer = (data.content || []).map(c => c.text || '').join('').trim();
    answerEl.innerHTML = `<div style="font-size:0.72rem;color:var(--accent);font-weight:700;font-family:'DM Mono',monospace;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px">🤖 Bauberater</div>${answer}`;
    document.getElementById('ki-chat-input').value = '';

  } catch(e) {
    answerEl.innerHTML = `<span style="color:var(--danger)">⚠️ Fehler – bitte erneut versuchen.</span>`;
  }

  btn.disabled = false;
  btn.textContent = 'Fragen →';
}

// ──────────────── PROJECT MANAGEMENT UI ────────────────
function renderProjectSwitcher() {
  const container = document.getElementById('project-list');
  if (!container) return;
  container.innerHTML = projects.map(p => {
    const isCurrent = p.id === currentProjectId;
    const color = p.settings?.color || '#3d6ff8';
    const spent = (p.kosten||[]).filter(k=>k.status!=='Storniert').reduce((s,k)=>s+(parseFloat(k.betrag)||0),0);
    const budget = (p.budgetKat||[]).reduce((s,k)=>s+k.budget,0);
    const pct = budget>0 ? Math.round(spent/budget*100) : 0;
    const modCount = Object.values(p.settings?.modules||{}).filter(v=>v!==false).length || MODULES.length;
    return `
    <div onclick="switchToProject(${p.id})"
      style="display:flex;align-items:center;gap:14px;padding:14px 16px;border-radius:12px;border:2px solid ${isCurrent?color:'var(--border)'};background:${isCurrent?color+'0f':'white'};cursor:pointer;transition:all 0.15s"
      onmouseover="if(!${isCurrent})this.style.borderColor='${color}';this.style.background='${color}0a'"
      onmouseout="if(!${isCurrent})this.style.borderColor='var(--border)';this.style.background='white'">
      <div style="width:40px;height:40px;border-radius:10px;background:${color};display:flex;align-items:center;justify-content:center;color:white;font-size:1.1rem;flex-shrink:0">
        ${{Neubau:'🏠',Umbau:'🔨',Sanierung:'🔧',Sonstiges:'📋'}[p.settings?.type||'Neubau']}
      </div>
      <div style="flex:1;min-width:0">
        <div style="font-weight:700;font-size:0.92rem;color:var(--text);display:flex;align-items:center;gap:8px">
          ${p.settings?.name || 'Projekt'}
          ${isCurrent ? `<span style="font-size:0.62rem;background:${color};color:white;padding:2px 8px;border-radius:99px;font-family:'DM Mono',monospace">AKTIV</span>` : ''}
        </div>
        <div style="font-size:0.75rem;color:var(--text3);margin-top:2px;font-family:'DM Mono',monospace">
          ${p.settings?.address||'Keine Adresse'} · ${budget>0?`Budget: ${fmt(budget)}`:'Kein Budget'}
        </div>
        ${budget>0?`<div style="margin-top:6px;height:4px;background:var(--surface3);border-radius:99px;overflow:hidden">
          <div style="width:${Math.min(100,pct)}%;height:100%;background:${pct>90?'var(--danger)':color};border-radius:99px"></div>
        </div>`:''}
      </div>
      <div style="display:flex;gap:6px;flex-shrink:0">
        <button class="action-btn" title="Bearbeiten" onclick="event.stopPropagation();editProject(${p.id})">✏️</button>
        ${projects.length > 1 ? `<button class="action-btn del" title="Löschen" onclick="event.stopPropagation();deleteProject(${p.id})">🗑</button>` : ''}
      </div>
    </div>`;
  }).join('');
}

function switchToProject(id) {
  closeModal('modal-project-switcher');
  loadProject(id, true);
  showToast(`📂 Gewechselt zu: ${projects.find(p=>p.id===id)?.settings?.name}`, 'success');
}

function deleteProject(id) {
  if (projects.length <= 1) { alert('Du kannst das letzte Projekt nicht löschen.'); return; }
  const name = projects.find(p=>p.id===id)?.settings?.name;
  if (!confirm(`Projekt "${name}" und alle Daten löschen?`)) return;
  projects = projects.filter(p => p.id !== id);
  if (currentProjectId === id) loadProject(projects[0].id, true);
  saveAll();
  renderProjectSwitcher();
}

function editProject(id) {
  closeModal('modal-project-switcher');
  const p = projects.find(p => p.id === id);
  if (!p) return;
  document.getElementById('edit-proj-id').value = id;
  document.getElementById('new-proj-title').textContent = 'Projekt bearbeiten';
  document.getElementById('np-name').value    = p.settings?.name    || '';
  document.getElementById('np-address').value = p.settings?.address || '';
  document.getElementById('np-start').value   = p.settings?.start   || '';
  document.getElementById('np-end').value     = p.settings?.end     || '';
  const typeEl = document.getElementById('np-type');
  Array.from(typeEl.options).forEach(o => { if (o.value === p.settings?.type) o.selected = true; });
  renderNewProjectColorPicker(p.settings?.color || '#3d6ff8');
  renderNewProjectModules(p.settings?.modules || {});
  openModal('modal-new-project');
}

function saveProject() {
  const editId = parseInt(document.getElementById('edit-proj-id').value) || null;
  const selectedColor = document.querySelector('#np-color-picker .color-dot.selected')?.dataset.color || '#3d6ff8';
  const modules = {};
  document.querySelectorAll('#np-module-grid input[type=checkbox]').forEach(cb => {
    modules[cb.dataset.module] = cb.checked;
  });

  if (editId) {
    const p = projects.find(p => p.id === editId);
    if (p) {
      p.settings.name    = document.getElementById('np-name').value || 'Projekt';
      p.settings.type    = document.getElementById('np-type').value;
      p.settings.address = document.getElementById('np-address').value;
      p.settings.start   = document.getElementById('np-start').value;
      p.settings.end     = document.getElementById('np-end').value;
      p.settings.color   = selectedColor;
      p.settings.modules = modules;
      if (editId === currentProjectId) {
        state.settings = { ...p.settings };
        updateProjectHeader();
        applyModuleVisibility();
      }
    }
  } else {
    // New project
    const proj = EMPTY_PROJECT();
    proj.settings.name    = document.getElementById('np-name').value || 'Neues Projekt';
    proj.settings.type    = document.getElementById('np-type').value;
    proj.settings.address = document.getElementById('np-address').value;
    proj.settings.start   = document.getElementById('np-start').value;
    proj.settings.end     = document.getElementById('np-end').value;
    proj.settings.color   = selectedColor;
    proj.settings.modules = modules;
    projects.push(proj);
    saveAll();
    closeModal('modal-new-project');
    loadProject(proj.id, true);
    showToast(`✅ Projekt "${proj.settings.name}" angelegt`, 'success');
    return;
  }

  saveAll();
  closeModal('modal-new-project');
  document.getElementById('edit-proj-id').value = '';
  document.getElementById('new-proj-title').textContent = 'Neues Projekt';
  showToast('✅ Projekt gespeichert', 'success');
}

function renderNewProjectColorPicker(selectedColor) {
  const container = document.getElementById('np-color-picker');
  if (!container) return;
  container.innerHTML = PROJECT_COLORS.map(c => `
    <div class="color-dot ${c===selectedColor?'selected':''}" data-color="${c}"
      onclick="document.querySelectorAll('.color-dot').forEach(d=>d.classList.remove('selected'));this.classList.add('selected')"
