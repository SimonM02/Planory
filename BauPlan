// ──────────────── KOSTEN MwSt-Helpers ────────────────
function updateKostenBrutto() {
  const netto = parseFloat(document.getElementById('k-netto-input').value) || 0;
  const mwst = parseFloat(document.getElementById('k-mwst').value) || 0;
  const brutto = netto * (1 + mwst / 100);
  if (netto > 0) document.getElementById('k-betrag').value = brutto.toFixed(2);
  const mwstBetrag = brutto - netto;
  document.getElementById('k-mwst-preview').textContent = `Netto: ${fmt(netto)}  ·  MwSt (${mwst}%): ${fmt(mwstBetrag)}  ·  Brutto: ${fmt(brutto)}`;
}

function updateKostenNetto() {
  const brutto = parseFloat(document.getElementById('k-betrag').value) || 0;
  const mwst = parseFloat(document.getElementById('k-mwst').value) || 0;
  const netto = mwst > 0 ? brutto / (1 + mwst / 100) : brutto;
  if (brutto > 0) document.getElementById('k-netto-input').value = netto.toFixed(2);
  const mwstBetrag = brutto - netto;
  document.getElementById('k-mwst-preview').textContent = `Netto: ${fmt(netto)}  ·  MwSt (${mwst}%): ${fmt(mwstBetrag)}  ·  Brutto: ${fmt(brutto)}`;
}

let kostenTab = 'ausgaben';
function switchKostenTab(tab, btn) {
