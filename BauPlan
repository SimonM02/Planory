// ──────────────── KATEGORIE SYSTEM ────────────────
const FALLBACK_KATS = ['Rohbau','Dach','Fenster & Türen','Elektro','Sanitär','Heizung','Innenausbau','Außenanlagen','Sonstiges'];

function getKatList() {
  // Merge budget categories + fallbacks, deduplicated
  const budgetNames = (state.budgetKat || []).map(k => k.name);
  const all = [...budgetNames, ...FALLBACK_KATS.filter(f => !budgetNames.includes(f))];
  return all;
}

function getKatOptions(selectedVal = '') {
  return getKatList().map(k =>
    `<option value="${k}" ${k === selectedVal ? 'selected' : ''}>${k}</option>`
  ).join('');
}

function refreshAllKatSelects(selectedVal = '') {
  const ids = ['k-kat','el-kat','scan-kat'];
  ids.forEach(id => {
    const el = document.getElementById(id);
    if (el) el.innerHTML = getKatOptions(selectedVal);
  });
  // foto-filter
  const ff = document.getElementById('foto-filter');
  if (ff) {
    const cur = ff.value;
    ff.innerHTML = `<option value="">Alle Kategorien</option>` + getKatList().map(k =>
      `<option value="${k}" ${k === cur ? 'selected' : ''}>${k}</option>`).join('');
  }
}

// ──────────────── KOSTEN ADD / EDIT ────────────────
function saveKosten() {
  const editId = parseInt(document.getElementById('k-edit-id').value) || null;
  const mwstRate = parseFloat(document.getElementById('k-mwst').value) || 0;
  const brutto   = parseFloat(document.getElementById('k-betrag').value) || 0;
  const netto    = mwstRate > 0 ? brutto / (1 + mwstRate / 100) : brutto;
  const item = {
    id:      editId || Date.now(),
    datum:   document.getElementById('k-datum').value || today(),
    beschr:  document.getElementById('k-beschr').value || 'Unbenannte Ausgabe',
    kat:     document.getElementById('k-kat').value,
    mwst:    mwstRate,
    netto:   parseFloat(netto.toFixed(2)),
    betrag:  brutto,
    status:  document.getElementById('k-status').value,
    anbieter: document.getElementById('k-anbieter').value,
    aiScanned: editId ? (state.kosten.find(k => k.id === editId)?.aiScanned || false) : false
  };

  if (editId) {
    const idx = state.kosten.findIndex(k => k.id === editId);
    if (idx > -1) state.kosten[idx] = item;
  } else {
    state.kosten.push(item);
  }
  save();
  closeModal('modal-kosten');
  document.getElementById('k-edit-id').value = '';
  document.getElementById('k-modal-title').textContent = 'Ausgabe erfassen';
  ['k-datum','k-beschr','k-betrag','k-netto-input','k-anbieter'].forEach(id => document.getElementById(id).value = '');
  document.getElementById('k-mwst-preview').textContent = 'MwSt-Betrag: € 0,00';
  renderKosten();
  renderBudget();
  showToast(editId ? '✏️ Ausgabe aktualisiert' : '✅ Ausgabe eingebucht', 'success');
}

function editKosten(id) {
  const k = state.kosten.find(k => k.id === id);
  if (!k) return;
  refreshAllKatSelects(k.kat);
  document.getElementById('k-modal-title').textContent = 'Ausgabe bearbeiten';
  document.getElementById('k-edit-id').value = k.id;
  document.getElementById('k-datum').value   = k.datum || '';
  document.getElementById('k-beschr').value  = k.beschr || '';
  document.getElementById('k-anbieter').value = k.anbieter || '';
  document.getElementById('k-betrag').value  = k.betrag || '';
  document.getElementById('k-netto-input').value = k.netto ?? k.betrag ?? '';
  const mwstSel = document.getElementById('k-mwst');
  Array.from(mwstSel.options).forEach(o => { if (o.value === String(k.mwst || 0)) o.selected = true; });
  const statusSel = document.getElementById('k-status');
  Array.from(statusSel.options).forEach(o => { if (o.value === k.status) o.selected = true; });
  updateKostenBrutto();
  openModal('modal-kosten');
}

function deleteKosten(id) {
  if (!confirm('Ausgabe löschen?')) return;
  state.kosten = state.kosten.filter(k => k.id !== id);
  save(); renderKosten(); renderBudget();
}

// Compatibility shim (old calls still work)
function addKosten() { saveKosten(); }

// ──────────────── BUDGET DRILLDOWN ────────────────
function openBudgetDrilldown(katName) {
  const kat    = state.budgetKat.find(b => b.name === katName) || {};
  const items  = state.kosten.filter(k => k.kat === katName && k.status !== 'Storniert');
  const budget = kat.budget || 0;
  const spent  = items.reduce((s,k) => s + (parseFloat(k.betrag)||0), 0);
  const rest   = budget - spent;
  const pct    = budget > 0 ? Math.round(spent / budget * 100) : 0;

  document.getElementById('drilldown-title').textContent = `📂 ${katName}`;
  document.getElementById('drilldown-summary').innerHTML = `
    <div class="card" style="padding:14px 16px">
      <div class="card-label">Budget</div>
      <div style="font-size:1.3rem;font-weight:800;font-family:'Plus Jakarta Sans',sans-serif">${fmt(budget)}</div>
    </div>
    <div class="card" style="padding:14px 16px">
      <div class="card-label">Ausgegeben</div>
      <div style="font-size:1.3rem;font-weight:800;color:var(--danger);font-family:'Plus Jakarta Sans',sans-serif">${fmt(spent)}</div>
      <div style="font-size:0.75rem;color:var(--text3);margin-top:3px">${items.length} Buchungen</div>
    </div>
    <div class="card" style="padding:14px 16px">
      <div class="card-label">Rest</div>
      <div style="font-size:1.3rem;font-weight:800;color:${rest>=0?'var(--success)':'var(--danger)'};font-family:'Plus Jakarta Sans',sans-serif">${fmt(rest)}</div>
      <div style="font-size:0.75rem;color:var(--text3);margin-top:3px">${pct}% verbraucht</div>
    </div>`;

  // progress bar inside drilldown
  document.getElementById('drilldown-progress').style.width = Math.min(100, pct) + '%';
  document.getElementById('drilldown-progress').style.background = pct > 90 ? 'var(--danger)' : pct > 70 ? 'var(--warning)' : 'var(--accent)';

  const tbody = document.getElementById('drilldown-table');
  if (items.length === 0) {
    tbody.innerHTML = `<tr><td colspan="7" style="text-align:center;padding:28px;color:var(--text3);font-weight:500">Noch keine Buchungen in dieser Kategorie</td></tr>`;
  } else {
    tbody.innerHTML = [...items].sort((a,b) => new Date(b.datum) - new Date(a.datum)).map(k => {
      const netto = k.netto ?? k.betrag;
      return `<tr>
        <td style="font-family:'DM Mono',monospace;font-size:0.77rem">${fmtDate(k.datum)}</td>
        <td style="font-weight:600">${k.beschr}${k.aiScanned?` <span class="badge badge-purple" style="font-size:0.6rem">🤖</span>`:''}</td>
        <td style="font-size:0.82rem;color:var(--text2)">${k.anbieter||'–'}</td>
        <td style="font-family:'DM Mono',monospace;font-size:0.82rem">${fmt(netto)}</td>
        <td style="font-family:'DM Mono',monospace;font-weight:700">${fmt(k.betrag)}</td>
        <td><span class="badge ${k.status==='Bezahlt'?'badge-green':k.status==='Ausstehend'?'badge-yellow':'badge-red'}">${k.status}</span></td>
        <td style="display:flex;gap:4px">
          <button class="action-btn" title="Bearbeiten" onclick="closeModal('modal-budget-drilldown');editKosten(${k.id})">✏️</button>
          <button class="action-btn del" title="Löschen" onclick="deleteDrilldownKosten(${k.id},'${katName.replace(/'/g,"\\'")}')">🗑</button>
        </td>
      </tr>`;
    }).join('');
  }

  // pre-select kat for new entry
  setTimeout(() => refreshAllKatSelects(katName), 50);
  openModal('modal-budget-drilldown');
}

function deleteDrilldownKosten(id, katName) {
  if (!confirm('Ausgabe löschen?')) return;
  state.kosten = state.kosten.filter(k => k.id !== id);
  save();
  renderKosten();
  renderBudget();
  openBudgetDrilldown(katName); // refresh drilldown
}

