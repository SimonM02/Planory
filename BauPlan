function addDiary() {
  // collect workers
  const workers = [];
  document.querySelectorAll('#tb-worker-rows > div').forEach(row => {
    const name = row.querySelector('.tb-worker-name')?.value?.trim();
    const hours = parseFloat(row.querySelector('.tb-worker-hours')?.value) || 0;
