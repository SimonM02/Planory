async function runKIAnalysis() {
  const snapshot = buildProjectSnapshot();
  document.getElementById('ki-empty').style.display    = 'none';
  document.getElementById('ki-results').style.display  = 'none';
  document.getElementById('ki-loading').style.display  = 'block';
  document.getElementById('ki-analyze-btn').disabled   = true;

  try {
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 2000,
        system: buildSystemPrompt(),
        messages: [{
          role: 'user',
          content: `Analysiere dieses Bauprojekt:\n\n${JSON.stringify(snapshot, null, 2)}`
        }]
      })
    });

    const data = await resp.json();
    const text = (data.content || []).map(c => c.text || '').join('').replace(/```json|```/g,'').trim();
    const result = JSON.parse(text);
    renderKIResults(result, snapshot);

  } catch(e) {
    document.getElementById('ki-loading').style.display = 'none';
    document.getElementById('ki-empty').style.display   = 'block';
    document.getElementById('ki-empty').innerHTML = `<div style="padding:14px 16px;background:var(--danger-light);border-radius:11px;border:1.5px solid #fecaca;color:var(--danger);font-weight:600;font-size:0.85rem">⚠️ Analyse fehlgeschlagen – bitte erneut versuchen.</div>`;
  }
  document.getElementById('ki-analyze-btn').disabled = false;
}

