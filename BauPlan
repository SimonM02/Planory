<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
<script>
// ──────────────── STATE ────────────────
// ──────────────── MULTI-PROJECT STATE ────────────────
const EMPTY_PROJECT = () => ({
  id: Date.now(),
  settings: { name: 'Neues Projekt', type: 'Neubau', budget: 0, start: '', end: '', address: '', color: '#3d6ff8', modules: {} },
  kosten: [], eigenleistungen: [], budgetKat: [],
  meilensteine: [], aufgaben: [], tagebuch: [],
  notizen: [], kontakte: [], gantt: [], fotos: [],
  dokumentation: [], wartungen: []
});

let projects = [];      // array of all projects
let currentProjectId = null;
let state = EMPTY_PROJECT(); // active project data (alias)

const PROJECT_COLORS = ['#3d6ff8','#7b5cfa','#0d9488','#ea6c19','#ef4444','#f59e0b','#22c55e','#e879f9','#06b6d4','#64748b'];

function saveAll() {
  // Sync active state back into projects array
  const idx = projects.findIndex(p => p.id === currentProjectId);
  if (idx > -1) projects[idx] = { ...state, id: currentProjectId };
  localStorage.setItem('bauplan_projects', JSON.stringify(projects));
  localStorage.setItem('bauplan_current', String(currentProjectId));
}

function save() { saveAll(); }

function loadAll() {
  const raw = localStorage.getItem('bauplan_projects');
  const cur = localStorage.getItem('bauplan_current');
  if (raw) {
    projects = JSON.parse(raw);
  } else {
    // Migrate old single-project data
    const old = localStorage.getItem('bauplan_data');
    const firstProject = EMPTY_PROJECT();
    if (old) {
      const parsed = JSON.parse(old);
      Object.assign(firstProject, parsed);
      firstProject.settings = { ...firstProject.settings, name: parsed.settings?.name || 'Mein Projekt', color: '#3d6ff8' };
    } else {
      firstProject.settings.name = 'Mein erstes Projekt';
    }
    projects = [firstProject];
  }
  // Set active project
  const savedId = cur ? parseInt(cur) : null;
  const found = savedId && projects.find(p => p.id === savedId);
  currentProjectId = found ? found.id : projects[0].id;
  loadProject(currentProjectId, false);
}

function load() { loadAll(); } // compatibility

function loadProject(id, rerender = true) {
  const proj = projects.find(p => p.id === id);
  if (!proj) return;
  currentProjectId = id;
  // Deep-copy into state
  state = JSON.parse(JSON.stringify(proj));
  updateProjectHeader();
  applyModuleVisibility();
  if (rerender) {
    showPage('dashboard');
    saveAll();
  }
}

function updateProjectHeader() {
  const s = state.settings;
  const nameEl = document.getElementById('current-project-name');
  const subEl  = document.getElementById('current-project-sub');
  if (nameEl) nameEl.textContent = s.name || 'BauPlan';
  if (subEl)  subEl.textContent  = (s.type || '') + (projects.length > 1 ? ` · ${projects.length} Projekte` : '');

  // Sidebar accent color per project
  const color = s.color || '#3d6ff8';
  document.documentElement.style.setProperty('--accent', color);
  // derive accent2 (lighter)
  document.documentElement.style.setProperty('--accent2', color + 'cc');
  document.documentElement.style.setProperty('--accent-light', color + '18');
  document.documentElement.style.setProperty('--accent-grad', `linear-gradient(135deg, ${color}, ${color}cc)`);
}

// ──────────────── NAVIGATION ────────────────
function showPage(id) {
  document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
  document.getElementById('page-' + id).classList.add('active');
  event && event.currentTarget && event.currentTarget.classList.add('active');
  // re-render
  if (id === 'dashboard') renderDashboard();
  if (id === 'kosten') renderKosten();
  if (id === 'budget') renderBudget();
  if (id === 'meilensteine') renderMilestones();
  if (id === 'aufgaben') renderTasks();
  if (id === 'tagebuch') { diaryTab='log'; renderDiary(); document.getElementById('diary-list').style.display=''; document.getElementById('diary-summary').style.display='none'; document.getElementById('diary-tab-log')?.classList.add('active'); document.getElementById('diary-tab-summary')?.classList.remove('active'); }
  if (id === 'dokumente') renderNotizen();
  if (id === 'kontakte') renderKontakte();
  if (id === 'gantt') renderGantt();
  if (id === 'fotos') renderFotos();
  if (id === 'kostenchart') renderKostenChart();
  if (id === 'dokumentation') renderDoku();
  if (id === 'wartung') renderWartung();
  if (id === 'settings') loadSettings();
}

// ──────────────── UTILS ────────────────
const fmt = (n) => '€ ' + Number(n).toLocaleString('de-AT', {minimumFractionDigits:2, maximumFractionDigits:2});
const fmtDate = (d) => d ? new Date(d).toLocaleDateString('de-AT') : '–';
const today = () => new Date().toISOString().split('T')[0];

function openModal(id) {
  document.getElementById(id).classList.add('open');
  const d = document.querySelector('#' + id + ' input[type="date"]');
  if (d && !d.value) d.value = today();
  if (id === 'modal-budget-kat') renderBudgetPresets();
  if (id === 'modal-kosten' || id === 'modal-eigenleistung' || id === 'modal-rechnung-scan') {
    const editId = document.getElementById('k-edit-id')?.value;
    if (!editId) refreshAllKatSelects();
  }
  // Project modals
  if (id === 'modal-project-switcher') renderProjectSwitcher();
  if (id === 'modal-new-project') {
    const isEdit = !!document.getElementById('edit-proj-id').value;
    if (!isEdit) {
      renderNewProjectColorPicker('#3d6ff8');
      renderNewProjectModules({});
      ['np-name','np-address','np-start','np-end'].forEach(i => { const el = document.getElementById(i); if(el) el.value=''; });
    }
  }
}

function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// close on overlay click
document.querySelectorAll('.modal-overlay').forEach(o => {
  o.addEventListener('click', e => { if (e.target === o) o.classList.remove('open'); });
});

// ──────────────── SETTINGS ────────────────
// ──────────────── MODULES ────────────────
const MODULES = [
  { id: 'kosten',        label: 'Kostenverfolgung',   icon: '💶', group: 'Finanzen',   default: true },
  { id: 'kostenchart',   label: 'Kostenentwicklung',  icon: '📈', group: 'Finanzen',   default: true },
  { id: 'budget',        label: 'Budgetplan',          icon: '📊', group: 'Finanzen',   default: true },
  { id: 'gantt',         label: 'Gantt-Zeitplan',      icon: '📅', group: 'Planung',    default: true },
  { id: 'meilensteine',  label: 'Meilensteine',        icon: '🏁', group: 'Planung',    default: true },
  { id: 'aufgaben',      label: 'Aufgaben',            icon: '✅', group: 'Planung',    default: true },
  { id: 'fotos',         label: 'Foto-Galerie',        icon: '📸', group: 'Tagebuch',   default: true },
  { id: 'tagebuch',      label: 'Bautagebuch',         icon: '📓', group: 'Tagebuch',   default: true },
  { id: 'notizen',       label: 'Notizen',             icon: '📎', group: 'Tagebuch',   default: true },
  { id: 'kontakte',      label: 'Handwerker',          icon: '👷', group: 'Kontakte',   default: true },
  { id: 'dokumentation', label: 'Dokumentation',       icon: '📐', group: 'Gebäude',    default: true },
  { id: 'wartung',       label: 'Wartungsplan',        icon: '🔧', group: 'Gebäude',    default: true },
];

function getModules() {
  const saved = state.settings.modules || {};
  const result = {};
  MODULES.forEach(m => {
    result[m.id] = saved[m.id] !== undefined ? saved[m.id] : m.default;
  });
  return result;
}

function toggleModule(id) {
  if (!state.settings.modules) state.settings.modules = {};
  const current = getModules()[id];
  state.settings.modules[id] = !current;
  save();
  applyModuleVisibility();
  renderModuleToggles();
}

function applyModuleVisibility() {
  const mods = getModules();
  MODULES.forEach(m => {
    const isOn = mods[m.id];
    // nav items
    document.querySelectorAll(`[data-module="${m.id}"]`).forEach(el => {
      el.style.display = isOn ? '' : 'none';
    });
  });
  // Hide section headers if all items in group hidden
  const groups = ['finanzen','planung','tagebuch_gruppe','kontakte_gruppe','gebaeude'];
  groups.forEach(g => {
    const header = document.querySelector(`[data-module="${g}"]`);
    if (!header) return;
    // check sibling nav items until next section
    let el = header.nextElementSibling;
    let anyVisible = false;
    while (el && !el.classList.contains('nav-section')) {
      if (el.style.display !== 'none') anyVisible = true;
      el = el.nextElementSibling;
    }
    header.style.display = anyVisible ? '' : 'none';
  });
}

function renderModuleToggles() {
  const container = document.getElementById('module-toggles');
  if (!container) return;
  const mods = getModules();
  const groups = [...new Set(MODULES.map(m => m.group))];

  container.innerHTML = groups.map(g => {
    const items = MODULES.filter(m => m.group === g);
    return `
      <div style="margin-bottom:14px">
        <div style="font-family:'DM Mono',monospace;font-size:0.62rem;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;margin-bottom:8px;font-weight:600">${g}</div>
        ${items.map(m => {
          const on = mods[m.id];
          return `
          <div onclick="toggleModule('${m.id}')"
            style="display:flex;align-items:center;justify-content:space-between;padding:10px 14px;border-radius:10px;cursor:pointer;transition:background 0.15s;margin-bottom:3px"
            onmouseover="this.style.background='var(--surface2)'" onmouseout="this.style.background='transparent'">
            <div style="display:flex;align-items:center;gap:10px">
              <span style="font-size:1rem;width:24px;text-align:center">${m.icon}</span>
              <span style="font-size:0.875rem;font-weight:${on?'600':'400'};color:${on?'var(--text)':'var(--text3)'}">${m.label}</span>
            </div>
            <!-- Toggle switch -->
            <div style="width:44px;height:24px;border-radius:99px;background:${on?'var(--accent)':'var(--border)'};position:relative;transition:background 0.2s;flex-shrink:0">
              <div style="position:absolute;top:3px;left:${on?'23px':'3px'};width:18px;height:18px;border-radius:50%;background:white;transition:left 0.2s;box-shadow:0 1px 4px rgba(0,0,0,0.2)"></div>
            </div>
          </div>`;
        }).join('')}
      </div>`;
  }).join('');
}

// ──────────────── SETTINGS ────────────────
function saveSettings() {
  state.settings.name    = document.getElementById('s-name').value;
  state.settings.start   = document.getElementById('s-start').value;
  state.settings.end     = document.getElementById('s-end').value;
  state.settings.address = document.getElementById('s-address').value;
  saveAll();
  updateProjectHeader();
}

function loadSettings() {
  document.getElementById('s-name').value    = state.settings.name    || '';
  document.getElementById('s-start').value   = state.settings.start   || '';
  document.getElementById('s-end').value     = state.settings.end     || '';
  document.getElementById('s-address').value = state.settings.address || '';
  renderModuleToggles();
}

// ──────────────── DASHBOARD ────────────────
function renderDashboard() {
  const total = state.kosten.reduce((s, k) => s + (k.status !== 'Storniert' ? parseFloat(k.betrag)||0 : 0), 0);
  const budget = state.settings.budget || 0;
  const remaining = budget - total;
  const done = state.meilensteine.filter(m => m.done).length;
  const all = state.meilensteine.length;
  const pct = budget > 0 ? Math.min(100, Math.round(total / budget * 100)) : 0;

  document.getElementById('d-budget').textContent = fmt(budget);
  document.getElementById('d-spent').textContent = fmt(total);
  document.getElementById('d-remaining').textContent = fmt(remaining);
  document.getElementById('d-remaining').className = 'card-value ' + (remaining >= 0 ? 'green' : 'red');
  document.getElementById('d-progress').textContent = all ? `${done}/${all}` : '–';
  document.getElementById('d-pct').textContent = pct + '%';
  document.getElementById('d-bar').style.width = pct + '%';
  document.getElementById('d-bar').style.background = pct > 90 ? 'var(--danger)' : pct > 70 ? 'var(--warning)' : 'linear-gradient(90deg, var(--accent), var(--accent2))';

  if (state.settings.name) document.getElementById('dashboard-subtitle').textContent = state.settings.name + (state.settings.address ? ' · ' + state.settings.address : '');

  // recent costs
  const recent = [...state.kosten].reverse().slice(0, 5);
  const tbody = document.getElementById('dash-recent-costs');
  if (recent.length === 0) {
    tbody.innerHTML = '<tr><td colspan="3" style="color:var(--text3);text-align:center;padding:20px">Noch keine Ausgaben</td></tr>';
  } else {
    tbody.innerHTML = recent.map(k => `
      <tr>
        <td style="font-family:'DM Mono',monospace;font-size:0.78rem">${fmtDate(k.datum)}</td>
        <td>${k.beschr}</td>
        <td style="font-family:'DM Mono',monospace">${fmt(k.betrag)}</td>
      </tr>`).join('');
  }

  // open tasks
  const openTasks = state.aufgaben.filter(t => t.status !== 'Erledigt').slice(0, 5);
  const ttbody = document.getElementById('dash-tasks');
  if (openTasks.length === 0) {
    ttbody.innerHTML = '<tr><td colspan="3" style="color:var(--text3);text-align:center;padding:20px">Keine offenen Aufgaben</td></tr>';
  } else {
    ttbody.innerHTML = openTasks.map(t => `
      <tr>
        <td>${t.name}</td>
        <td><span class="badge ${t.prio==='Hoch'?'badge-red':t.prio==='Mittel'?'badge-yellow':'badge-gray'}">${t.prio}</span></td>
        <td><span class="badge badge-blue">${t.status}</span></td>
      </tr>`).join('');
  }
}

