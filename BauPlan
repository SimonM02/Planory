  const newTotal = currentTotal + val;
  const el = document.getElementById('bk-preview');
  if (val > 0) {
    const pct = newTotal > 0 ? (val / newTotal * 100).toFixed(0) : 0;
    el.textContent = `Neues Gesamtbudget: ${fmt(newTotal)} · Anteil dieser Kategorie: ${pct}%`;
  } else {
    el.textContent = '';
  }
}

function addBudgetKat() {
  const name = document.getElementById('bk-name').value.trim();
  const budget = parseFloat(document.getElementById('bk-budget').value) || 0;
