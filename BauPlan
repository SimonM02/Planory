async function onAuthSuccess(user, isNewUser = false) {
  currentUser = user;
  hideAuthOverlay();
  const emailEl = document.getElementById('auth-user-email');
  if (emailEl) emailEl.textContent = user.email;

  // Load data from cloud
  await loadFromCloud();

  const hasOnboarded = localStorage.getItem('bauplan_onboarded_' + user.id);
  if (isNewUser || !hasOnboarded) {
    showOnboarding();
  } else {
    applyModuleVisibility();
    renderDashboard();
  }
}

// ── CLOUD SYNC ──────────────────────────────────
async function syncToCloud() {
  if (!currentUser) return;
  try {
    // Sync active state back
    const idx = projects.findIndex(p => p.id === currentProjectId);
    if (idx > -1) projects[idx] = { ...state, id: currentProjectId };

    const { error } = await supa.from('projektdaten').upsert({
      user_id: currentUser.id,
      projekt_id: 1, // we use a single JSON blob approach
      typ: 'all_projects',
      daten: { projects, currentProjectId },
      updated_at: new Date().toISOString()
    }, { onConflict: 'user_id,typ' });

    if (!error) {
      // Also keep local backup
      localStorage.setItem('bauplan_projects', JSON.stringify(projects));
      localStorage.setItem('bauplan_current', String(currentProjectId));
    }
  } catch(e) {
    // Silently fail, local storage is backup
  }
}

async function loadFromCloud() {
  if (!currentUser) return;
  try {
    const { data, error } = await supa.from('projektdaten')
      .select('daten')
      .eq('user_id', currentUser.id)
      .eq('typ', 'all_projects')
      .single();

    if (data?.daten) {
      projects = data.daten.projects || [];
      const savedId = data.daten.currentProjectId;
      const found = savedId && projects.find(p => p.id === savedId);
      currentProjectId = found ? found.id : projects[0]?.id;
      if (currentProjectId) loadProject(currentProjectId, false);
      return;
    }
  } catch(e) {}

  // Fallback to localStorage
  loadAll();
}

// Debounced auto-sync – saves 2 seconds after last change
const origSave = save;
function save() {
  origSave();
  if (currentUser) {
    clearTimeout(syncTimeout);
    syncTimeout = setTimeout(syncToCloud, 2000);
  }
}

// ── ONBOARDING ──────────────────────────────────
let obStep = 0;
let obType = 'Neubau';
const OB_TOTAL = 4;

function showOnboarding() {
  obStep = 0;
  obType = 'Neubau';
  document.getElementById('onboarding-overlay').style.display = 'block';
  renderObColorPicker('#3d6ff8');
  renderObModules();
  updateObUI();
}

function renderObColorPicker(sel) {
  const c = document.getElementById('ob-color-picker');
  if (!c) return;
  c.innerHTML = PROJECT_COLORS.map(col => `
    <div onclick="selectObColor('${col}',this)"
      style="width:28px;height:28px;border-radius:50%;background:${col};cursor:pointer;border:3px solid ${col===sel?'var(--text)':'transparent'};transition:transform 0.15s"
      onmouseover="this.style.transform='scale(1.2)'" onmouseout="this.style.transform='scale(1)'">
    </div>`).join('');
}

let obColor = '#3d6ff8';
function selectObColor(color, el) {
  obColor = color;
  document.querySelectorAll('#ob-color-picker div').forEach(d => d.style.border = '3px solid transparent');
  el.style.border = '3px solid var(--text)';
}

function selectObType(type, el) {
  obType = type;
  document.querySelectorAll('#ob-type-picker > div').forEach(d => {
    d.style.borderColor = 'var(--border)';
    d.style.background  = 'white';
    d.classList.remove('ob-selected');
  });
  el.style.borderColor = 'var(--accent)';
  el.style.background  = 'var(--accent-light)';
  el.classList.add('ob-selected');
}

function renderObModules() {
  const g = document.getElementById('ob-module-grid');
  if (!g) return;
  g.innerHTML = MODULES.map(m => `
    <label style="display:flex;align-items:center;gap:8px;padding:9px 12px;border-radius:10px;cursor:pointer;border:1.5px solid var(--border);background:white;transition:all 0.15s"
      onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
