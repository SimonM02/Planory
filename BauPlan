  state.wartungen = state.wartungen.filter(w => w.id !== id);
  save(); renderWartung();
}

function markWartungDone(id) {
  const w = (state.wartungen || []).find(w => w.id === id);
  if (w) { w.last = today(); save(); renderWartung(); }
}

function getNextDate(last, intervall, einheit) {
  const d = new Date(last);
  if (einheit === 'Wochen')  d.setDate(d.getDate() + intervall * 7);
  if (einheit === 'Monate')  d.setMonth(d.getMonth() + intervall);
  if (einheit === 'Jahre')   d.setFullYear(d.getFullYear() + intervall);
  return d;
}

function getDaysUntil(date) {
  return Math.round((date - new Date()) / 86400000);
}

const WARTUNG_ICONS = {
  '🔥 Heizung': '🔥', '💧 Wasser': '💧', '⚡ Elektro': '⚡',
  '🪟 Fenster & Türen': '🪟', '🌿 Außenanlage': '🌿',
  '🏠 Dach & Fassade': '🏠', '🔑 Sicherheit': '🔑', '📋 Sonstiges': '📋'
};
const WARTUNG_BG = {
  '🔥 Heizung': '#fff3e8', '💧 Wasser': '#e8f6ff', '⚡ Elektro': '#fffbe8',
  '🪟 Fenster & Türen': '#f0f8ff', '🌿 Außenanlage': '#f0fdf4',
  '🏠 Dach & Fassade': '#f5f5f5', '🔑 Sicherheit': '#fff0f0', '📋 Sonstiges': '#f8f8f8'
};

function renderWartung() {
  state.wartungen = state.wartungen || [];
  const list = document.getElementById('wartung-list');

  let overdue = 0, soon = 0, ok = 0;
  const sorted = [...state.wartungen].sort((a, b) => {
    return getDaysUntil(getNextDate(a.last, a.intervall, a.einheit))
         - getDaysUntil(getNextDate(b.last, b.intervall, b.einheit));
  });

  if (sorted.length === 0) {
    list.innerHTML = `<div class="empty"><div class="icon">🔧</div><p>Noch keine Wartungsaufgaben – lege z.B. Heizungsservice an!</p></div>`;
    document.getElementById('w-total').textContent = '0';
    document.getElementById('w-overdue').textContent = '0';
    document.getElementById('w-soon').textContent = '0';
    document.getElementById('w-ok').textContent = '0';
    return;
  }

  list.innerHTML = sorted.map(w => {
    const nextDate = getNextDate(w.last, w.intervall, w.einheit);
    const days     = getDaysUntil(nextDate);
    let statusClass, statusText;
    if (days < 0)  { overdue++; statusClass = 'overdue'; statusText = `${Math.abs(days)} Tage überfällig`; }
    else if (days <= 30) { soon++;   statusClass = 'soon';    statusText = `in ${days} Tagen fällig`; }
    else                 { ok++;     statusClass = 'ok';      statusText = `in ${days} Tagen (${fmtDate(nextDate.toISOString().split('T')[0])})`; }

    const icon = WARTUNG_ICONS[w.kat] || '📋';
    const bg   = WARTUNG_BG[w.kat]   || '#f8f8f8';
    const intervallLabel = `${w.intervall} ${w.einheit}`;

    return `
    <div class="wartung-item">
      <div class="wartung-icon" style="background:${bg}">${icon}</div>
      <div class="wartung-info">
        <div class="wartung-name">${w.name}</div>
        <div class="wartung-desc">${w.kat}${w.who ? ' · ' + w.who : ''}${w.kosten ? ' · ca. ' + fmt(w.kosten) : ''}</div>
        ${w.desc ? `<div style="font-size:0.78rem;color:var(--text3);margin-top:3px;line-height:1.4">${w.desc}</div>` : ''}
        <div class="wartung-next ${statusClass}">
          ${days < 0 ? '🔴' : days <= 30 ? '🟡' : '🟢'} ${statusText}
          · Zuletzt: ${fmtDate(w.last)}
        </div>
      </div>
      <div class="wartung-interval">
        <div class="wartung-interval-val">${w.intervall}</div>
        <div class="wartung-interval-unit">${w.einheit}</div>
      </div>
      <div style="display:flex;flex-direction:column;gap:4px">
        <button class="btn btn-primary" style="padding:6px 12px;font-size:0.75rem" onclick="markWartungDone(${w.id})" title="Als erledigt markieren">✓ Erledigt</button>
        <button class="action-btn del" onclick="deleteWartung(${w.id})">🗑</button>
      </div>
    </div>`;
  }).join('');

  document.getElementById('w-total').textContent = sorted.length;
  document.getElementById('w-overdue').textContent = overdue;
  document.getElementById('w-soon').textContent = soon;
  document.getElementById('w-ok').textContent = ok;
}

