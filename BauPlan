// ──────────────── KI-BAUBERATER ────────────────
function buildProjectSnapshot() {
  const paid = state.kosten.filter(k => k.status !== 'Storniert');
  const totalBudget = state.budgetKat.reduce((s,k) => s + k.budget, 0);
  const totalSpent  = paid.reduce((s,k) => s + (parseFloat(k.betrag)||0), 0);
  const budgetPct   = totalBudget > 0 ? Math.round(totalSpent / totalBudget * 100) : 0;
  const doneMilestones = state.meilensteine.filter(m => m.done).length;
  const allMilestones  = state.meilensteine.length;
  const progressPct    = allMilestones > 0 ? Math.round(doneMilestones / allMilestones * 100) : 0;

  // overdueWartungen
  const wartungen = state.wartungen || [];
  const overdueWartungen = wartungen.filter(w => {
    const next = getNextDate(w.last, w.intervall, w.einheit);
    return getDaysUntil(next) < 0;
  });
  const soonWartungen = wartungen.filter(w => {
    const d = getDaysUntil(getNextDate(w.last, w.intervall, w.einheit));
    return d >= 0 && d <= 30;
  });

  // category budget status
  const katStatus = state.budgetKat.map(k => {
    const spent = paid.filter(c => c.kat === k.name).reduce((s,c) => s + (parseFloat(c.betrag)||0), 0);
    const pct = k.budget > 0 ? Math.round(spent / k.budget * 100) : 0;
    return { name: k.name, budget: k.budget, spent, pct };
  });

  // open high-prio tasks
  const highPrioTasks = state.aufgaben.filter(t => t.status !== 'Erledigt' && t.prio === 'Hoch');
  const overdueTasks  = state.aufgaben.filter(t => t.status !== 'Erledigt' && t.datum && new Date(t.datum) < new Date());

  return {
    projektName: state.settings.name || 'Bauprojekt',
    adresse: state.settings.address || '',
    baubeginn: state.settings.start || '',
    fertigstellung: state.settings.end || '',
    totalBudget, totalSpent, budgetPct,
    doneMilestones, allMilestones, progressPct,
    anzahlAusgaben: paid.length,
    anzahlKategorien: state.budgetKat.length,
    katStatus,
    overdueWartungen: overdueWartungen.map(w => w.name),
    soonWartungen: soonWartungen.map(w => w.name),
    highPrioTasks: highPrioTasks.map(t => t.name),
    overdueTasks: overdueTasks.map(t => t.name),
    anzahlDokuEintraege: (state.dokumentation||[]).length,
    anzahlFotos: (state.fotos||[]).length,
    tagebuchEintraege: state.tagebuch.length,
    letzteAusgaben: [...paid].reverse().slice(0,5).map(k => `${fmtDate(k.datum)}: ${k.beschr} (${fmt(k.betrag)})`),
    naechsteMeilensteine: state.meilensteine.filter(m => !m.done).slice(0,3).map(m => `${m.name}${m.datum?' bis '+fmtDate(m.datum):''}`)
  };
}

