      const share   = totalBudget > 0 ? (kat.budget / totalBudget * 100).toFixed(1) : 0;
      const color   = BG_COLORS[i % BG_COLORS.length];
      return `<tr style="cursor:pointer" onclick="openBudgetDrilldown('${kat.name.replace(/'/g,"\\'")}')"
        onmouseover="this.style.background='#f0f5ff'" onmouseout="this.style.background=''">
        <td>
