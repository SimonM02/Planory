function addTask() {
  state.aufgaben.push({
    id: Date.now(),
    name: document.getElementById('t-name').value || 'Aufgabe',
    prio: document.getElementById('t-prio').value,
    datum: document.getElementById('t-datum').value,
    notiz: document.getElementById('t-notiz').value,
    status: 'Offen'
  });
  save(); closeModal('modal-task');
  ['t-name','t-datum','t-notiz'].forEach(id => document.getElementById(id).value = '');
  renderTasks();
}

function toggleTask(id) {
  const t = state.aufgaben.find(t => t.id === id);
  if (t) t.status = t.status === 'Erledigt' ? 'Offen' : 'Erledigt';
  save(); renderTasks();
}

function deleteTask(id) {
  if (!confirm('Aufgabe löschen?')) return;
  state.aufgaben = state.aufgaben.filter(t => t.id !== id);
  save(); renderTasks();
}

function renderTasks() {
  const tbody = document.getElementById('task-table');
  if (state.aufgaben.length === 0) {
    tbody.innerHTML = `<tr><td colspan="5"><div class="empty"><div class="icon">✅</div><p>Keine Aufgaben eingetragen</p></div></td></tr>`;
    return;
  }
  const sorted = [...state.aufgaben].sort((a,b) => {
    const po = {Hoch:0,Mittel:1,Niedrig:2};
    if (a.status==='Erledigt' && b.status!=='Erledigt') return 1;
    if (b.status==='Erledigt' && a.status!=='Erledigt') return -1;
    return (po[a.prio]||1) - (po[b.prio]||1);
  });
  tbody.innerHTML = sorted.map(t => `
    <tr>
      <td>
        <span style="${t.status==='Erledigt'?'text-decoration:line-through;color:var(--text3)':''}">${t.name}</span>
        ${t.notiz?`<br><span style="font-size:0.75rem;color:var(--text3)">${t.notiz}</span>`:''}
      </td>
      <td><span class="badge ${t.prio==='Hoch'?'badge-red':t.prio==='Mittel'?'badge-yellow':'badge-gray'}">${t.prio}</span></td>
      <td style="font-family:'DM Mono',monospace;font-size:0.78rem">${t.datum?fmtDate(t.datum):'–'}</td>
      <td><span class="badge ${t.status==='Erledigt'?'badge-green':'badge-blue'}">${t.status}</span></td>
      <td style="display:flex;gap:4px">
        <button class="action-btn" onclick="toggleTask(${t.id})">${t.status==='Erledigt'?'↩':'✓'}</button>
        <button class="action-btn del" onclick="deleteTask(${t.id})">🗑</button>
      </td>
    </tr>`).join('');
}

