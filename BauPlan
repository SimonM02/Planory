let scanImageBase64 = null;

function resetScanModal() {
  scanImageBase64 = null;
  document.getElementById('scan-preview').style.display = 'none';
  document.getElementById('scan-loading').style.display = 'none';
  document.getElementById('scan-result').style.display  = 'none';
  document.getElementById('scan-error').style.display   = 'none';
  document.getElementById('scan-confirm-btn').style.display = 'none';
  document.getElementById('scan-upload-area').style.display = 'block';
  document.getElementById('scan-file-input').value = '';
}

function scanUpdateBrutto() {
  const n = parseFloat(document.getElementById('scan-netto').value) || 0;
  const m = parseFloat(document.getElementById('scan-mwst').value) || 0;
  document.getElementById('scan-brutto').value = (n * (1 + m/100)).toFixed(2);
}

async function handleRechnungScan(input) {
  const file = input.files[0];
  if (!file) return;

  // Show preview for images
  if (file.type.startsWith('image/')) {
    const reader = new FileReader();
    reader.onload = e => {
      scanImageBase64 = e.target.result.split(',')[1];
      document.getElementById('scan-preview-img').src = e.target.result;
      document.getElementById('scan-preview').style.display = 'block';
    };
    reader.readAsDataURL(file);
  } else {
    // PDF – read as base64
    const reader = new FileReader();
    reader.onload = e => { scanImageBase64 = e.target.result.split(',')[1]; };
    reader.readAsDataURL(file);
  }

  document.getElementById('scan-upload-area').style.display = 'none';
  document.getElementById('scan-loading').style.display = 'block';
  document.getElementById('scan-result').style.display  = 'none';
  document.getElementById('scan-error').style.display   = 'none';
  document.getElementById('scan-confirm-btn').style.display = 'none';

  // Wait for file read
  await new Promise(r => setTimeout(r, 600));

  try {
    const isImage = file.type.startsWith('image/');
    const mediaType = file.type === 'application/pdf' ? 'application/pdf' : file.type || 'image/jpeg';

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        messages: [{
          role: 'user',
          content: [
            {
              type: isImage ? 'image' : 'document',
              source: { type: 'base64', media_type: mediaType, data: scanImageBase64 }
            },
            {
              type: 'text',
              text: `Analysiere diese Rechnung und extrahiere alle relevanten Informationen. Antworte NUR mit einem JSON-Objekt (kein Markdown, keine Erklärung):
{
  "beschreibung": "Kurze Beschreibung was berechnet wurde (max 60 Zeichen)",
  "anbieter": "Firmenname des Ausstellers",
  "datum": "YYYY-MM-DD Format",
  "netto": 0.00,
  "mwst_prozent": 20,
  "brutto": 0.00,
  "kategorie": "Eine von: Rohbau, Dach, Fenster & Türen, Elektro, Sanitär, Heizung, Innenausbau, Außenanlagen, Sonstiges",
  "hinweis": "Kurzer Hinweis zur Erkennung oder was auffällig ist (optional)"
}`
            }
          ]
        }]
      })
    });

    const data = await response.json();
    const text = data.content?.map(c => c.text || '').join('') || '';
    const clean = text.replace(/```json|```/g, '').trim();
    const parsed = JSON.parse(clean);

    // Fill form
    document.getElementById('scan-beschr').value   = parsed.beschreibung || '';
    document.getElementById('scan-anbieter').value  = parsed.anbieter     || '';
    document.getElementById('scan-datum').value     = parsed.datum        || today();
    document.getElementById('scan-netto').value     = parsed.netto        || '';
    document.getElementById('scan-brutto').value    = parsed.brutto       || '';
    document.getElementById('scan-ki-notiz').textContent = parsed.hinweis ? `💡 KI-Hinweis: ${parsed.hinweis}` : '';

    // Set MwSt
    const mwstSel = document.getElementById('scan-mwst');
    const mwstVal = String(parsed.mwst_prozent || 20);
    Array.from(mwstSel.options).forEach(o => { if (o.value === mwstVal) o.selected = true; });

    // Set Kategorie
    const katSel = document.getElementById('scan-kat');
    Array.from(katSel.options).forEach(o => { if (o.value === parsed.kategorie) o.selected = true; });

    document.getElementById('scan-loading').style.display = 'none';
    document.getElementById('scan-result').style.display  = 'block';
    document.getElementById('scan-confirm-btn').style.display = 'inline-flex';

  } catch(e) {
    document.getElementById('scan-loading').style.display = 'none';
    document.getElementById('scan-error').style.display   = 'block';
    document.getElementById('scan-error').textContent     = '⚠️ Rechnung konnte nicht ausgelesen werden. Bitte manuell eingeben oder anderes Bild versuchen.';
    document.getElementById('scan-upload-area').style.display = 'block';
  }
}

function confirmRechnungScan() {
  const brutto = parseFloat(document.getElementById('scan-brutto').value) || 0;
  const mwst   = parseFloat(document.getElementById('scan-mwst').value)   || 0;
  const netto  = mwst > 0 ? brutto / (1 + mwst/100) : brutto;

  state.kosten.push({
    id:      Date.now(),
    datum:   document.getElementById('scan-datum').value    || today(),
    beschr:  document.getElementById('scan-beschr').value   || 'Rechnung',
    kat:     document.getElementById('scan-kat').value,
    mwst,
    netto:   parseFloat(netto.toFixed(2)),
    betrag:  brutto,
    status:  document.getElementById('scan-status').value,
    anbieter: document.getElementById('scan-anbieter').value,
    aiScanned: true
  });
  save();
  closeModal('modal-rechnung-scan');
  resetScanModal();
  renderKosten();
  // small success toast
  showToast('✅ Rechnung erfolgreich eingebucht!', 'success');
}

