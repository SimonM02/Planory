{
  "appId": "com.planory.bau",
  "appName": "Planory",
  "webDir": "www",
  "server": {
    "allowNavigation": ["*.supabase.co"]
  },
  "ios": {
    "contentInset": "never"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "StatusBar": {
      "overlaysWebView": true,
      "style": "DEFAULT"
    }
  }
}
